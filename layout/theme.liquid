    <style>
      .becky-cart-overlay { position:fixed; inset:0; background:rgba(26,26,26,0.5); opacity:0; pointer-events:none; transition:opacity 200ms ease; z-index:200; }
      .becky-cart-overlay.is-open { opacity:1; pointer-events:auto; }
      /* 90s Windows cart drawer */
      .becky-cart-drawer { position:fixed; top:16px; right:16px; bottom:16px; width:calc(100% - 32px); max-width:460px; background:#c0c0c0; border:2px solid; border-color:#fff #5a5a5a #5a5a5a #fff; transform:translateX(calc(100% + 32px)); transition:transform 380ms cubic-bezier(0.34, 1.4, 0.64, 1); z-index:201; display:flex; flex-direction:column; box-shadow:6px 6px 0 rgba(0,0,0,0.18); padding:3px; }
      .becky-cart-drawer.is-open { transform:translateX(0); }
      .becky-cart-head { background:linear-gradient(90deg, #ff3465 0%, #d12950 100%); color:#fff; padding:6px 8px; display:flex; align-items:center; justify-content:space-between; font-family:'Poppins', sans-serif; font-weight:800; font-size:13px; letter-spacing:0.04em; flex-shrink:0; }
      .becky-cart-head h3 { font-size:13px; margin:0; color:#fff; font-weight:800; letter-spacing:0.04em; display:flex; align-items:center; gap:8px; }
      .becky-cart-head h3::before { content:''; display:inline-block; width:16px; height:16px; background:#fddbd1; border:1px solid #1a1a1a; background-image:url("{{ 'becky-pixel-peach.svg' | asset_url }}"); background-size:contain; background-repeat:no-repeat; background-position:center; }
      .becky-cart-head__controls { display:flex; gap:4px; }
      .becky-cart-head__control { width:20px; height:18px; background:#c0c0c0; border:1px solid; border-color:#fff #5a5a5a #5a5a5a #fff; color:#1a1a1a; font-size:11px; line-height:1; display:inline-flex; align-items:center; justify-content:center; font-family:'Poppins', sans-serif; font-weight:700; cursor:default; }
      .becky-cart-close { background:#c0c0c0; border:1px solid; border-color:#fff #5a5a5a #5a5a5a #fff; font-size:14px; font-weight:700; line-height:1; color:#1a1a1a; cursor:pointer; padding:0; width:20px; height:18px; display:inline-flex; align-items:center; justify-content:center; font-family:'Poppins', sans-serif; }
      .becky-cart-close:hover { background:#d8d8d8; }
      .becky-cart-close:active { border-color:#5a5a5a #fff #fff #5a5a5a; }
      .becky-cart-ship-top { padding:12px 16px; background:#c0c0c0; border-bottom:2px solid; border-color:#5a5a5a; }
      .becky-cart-ship-top:empty { display:none; }
      .becky-cart-body { flex:1; overflow-y:auto; padding:14px; background:#fff; border:2px solid; border-color:#5a5a5a #fff #fff #5a5a5a; }
      .becky-cart-empty { text-align:center; padding:32px 16px; }
      .becky-cart-empty h4 { font-size:16px; margin:0 0 8px; font-family:'Poppins', sans-serif; font-weight:800; }
      .becky-cart-item { display:grid; grid-template-columns:64px 1fr auto; gap:14px; padding:14px 0; border-bottom:1px dashed #d0d0d0; align-items:center; }
      .becky-cart-item:last-of-type { border-bottom:none; }
      .becky-cart-item__img { width:64px; height:64px; background:var(--becky-blush); overflow:hidden; display:flex; align-items:center; justify-content:center; border:2px solid; border-color:#5a5a5a #fff #fff #5a5a5a; position:relative; }
      .becky-cart-item__img img { width:100%; height:100%; object-fit:cover; }
      .becky-cart-item__img::before { content:'🍑'; position:absolute; top:-6px; left:-6px; width:16px; height:16px; background:#fff; border:1px solid #1a1a1a; font-size:10px; line-height:14px; text-align:center; }
      .becky-cart-item__title { font-weight:700; font-size:14px; margin:0 0 4px; font-family:'Poppins', sans-serif; letter-spacing:-0.01em; }
      .becky-cart-item__price { font-weight:800; color:var(--becky-pink); font-size:13px; font-family:'Poppins', sans-serif; }
      .becky-cart-item__qty { display:flex; align-items:center; gap:0; margin-top:6px; }
      .becky-cart-item__qty button { width:22px; height:22px; border:1px solid; border-color:#fff #5a5a5a #5a5a5a #fff; background:#c0c0c0; cursor:pointer; font-size:13px; font-weight:700; padding:0; font-family:'Poppins', sans-serif; }
      .becky-cart-item__qty button:hover { background:var(--becky-blush); }
      .becky-cart-item__qty button:active { border-color:#5a5a5a #fff #fff #5a5a5a; }
      .becky-cart-item__qty span { min-width:32px; height:22px; text-align:center; font-weight:700; background:#fff; border:1px solid; border-color:#5a5a5a #fff #fff #5a5a5a; line-height:22px; font-size:12px; font-family:'Poppins', sans-serif; }
      .becky-cart-item__remove { background:none; border:none; color:#888; cursor:pointer; font-size:10px; text-decoration:underline; padding:0; letter-spacing:0.04em; text-transform:uppercase; font-weight:700; margin-top:4px; }
      .becky-cart-item__remove:hover { color:var(--becky-pink); }
      .becky-cart-foot { padding:14px 16px; background:#c0c0c0; border-top:2px solid; border-color:#fff; }
      .becky-cart-ship { margin:0 0 16px; }
      .becky-cart-ship__label { display:flex; justify-content:space-between; align-items:center; font-size:13px; margin:0 0 8px; }
      .becky-cart-ship__label strong { font-weight:800; color:var(--becky-ink); }
      .becky-cart-ship__label .pct { font-family:'Poppins',sans-serif; font-weight:800; color:var(--becky-pink); }
      .becky-cart-ship__label .succ { color:var(--becky-pink); font-weight:800; font-family:'Poppins',sans-serif; }
      .becky-cart-ship__track { height:10px; background:#f0eded; border-radius:999px; overflow:hidden; position:relative; }
      .becky-cart-ship__fill { position:absolute; left:0; top:0; bottom:0; background:linear-gradient(90deg, #ff7a9a 0%, var(--becky-pink) 100%); border-radius:999px; transition:width 500ms cubic-bezier(0.4, 0, 0.2, 1); width:0; }
      .becky-cart-ship__fill.is-full { background:var(--becky-pink); }
      .becky-cart-ship__truck { position:absolute; top:50%; transform:translateY(-50%); font-size:14px; transition:left 500ms cubic-bezier(0.4, 0, 0.2, 1); }
      .becky-cart-subtotal { display:flex; justify-content:space-between; align-items:baseline; margin:16px 0 4px; padding-top:16px; border-top:1px solid var(--becky-border); }
      .becky-cart-subtotal strong { font-family:'Poppins',sans-serif; font-size:22px; font-weight:800; letter-spacing:-0.01em; }
      .becky-cart-checkout { display:flex; align-items:center; justify-content:center; gap:8px; width:100%; padding:14px; background:var(--becky-pink); color:#fff !important; border:2px solid; border-color:#ff7a9a #d12950 #d12950 #ff7a9a; font-weight:800; font-size:16px; text-decoration:none; font-family:'Poppins', sans-serif; cursor:pointer; letter-spacing:0.02em; margin:14px 0 0; }
      .becky-cart-checkout:hover { background:#d12950; }
      .becky-cart-checkout:active { border-color:#d12950 #ff7a9a #ff7a9a #d12950; padding:15px 14px 13px 14px; }
      .becky-cart-checkout::after { content:'→'; }
      .becky-cart-pay { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin:14px 0 0; }
      .becky-cart-pay__item { background:#f7f7f8; border-radius:8px; padding:10px; display:flex; align-items:center; justify-content:center; height:38px; font-size:11px; font-weight:700; color:var(--becky-ink); letter-spacing:0.02em; }
      .becky-cart-pay__item svg { height:18px; width:auto; }
      .becky-cart-trust { display:flex; gap:10px; justify-content:center; margin:14px 0 0; padding:8px 12px; background:#fff; border:1px solid; border-color:#5a5a5a #fff #fff #5a5a5a; font-size:10px; color:#5a5a5a; flex-wrap:wrap; letter-spacing:0.04em; font-weight:700; text-transform:uppercase; }
      .becky-cart-trust::before { content:'✓ Status:'; color:var(--becky-pink); font-weight:800; margin-right:4px; }
    </style>

    <!-- PIXEL PEACH CURSOR FOLLOWER -->
    <div id="beckyPeachCursor" aria-hidden="true">
      <img src="{{ 'becky-pixel-peach.svg' | asset_url }}" alt="" width="36" height="36">
    </div>
    <style>
      #beckyPeachCursor { position:fixed; top:0; left:0; width:36px; height:36px; pointer-events:none; z-index:9999; transform:translate(-50%,-50%) scale(0); opacity:0; transition:opacity 200ms ease, transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1); will-change:transform; }
      #beckyPeachCursor img { width:100%; height:100%; display:block; image-rendering:pixelated; image-rendering:crisp-edges; filter:drop-shadow(0 2px 6px rgba(255,52,101,0.25)); }
      #beckyPeachCursor.is-visible { opacity:1; transform:translate(-50%,-50%) scale(1) rotate(var(--peach-rot, 0deg)); }
      #beckyPeachCursor.is-hovering { transform:translate(-50%,-50%) scale(1.4) rotate(var(--peach-rot, 0deg)); }
      @media (hover:none), (pointer:coarse) { #beckyPeachCursor { display:none; } }
      @media (prefers-reduced-motion: reduce) { #beckyPeachCursor { display:none; } }
    </style>

    <script>
      (function() {
        var header = document.getElementById('beckyHeader');
        if (header) {
          window.addEventListener('scroll', function() {
            if (window.scrollY > 8) header.classList.add('is-scrolled');
            else header.classList.remove('is-scrolled');
          }, { passive: true });
        }

        // PIXEL PEACH CURSOR
        var peach = document.getElementById('beckyPeachCursor');
        if (peach && window.matchMedia('(hover:hover) and (pointer:fine)').matches && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          var targetX = window.innerWidth / 2, targetY = window.innerHeight / 2;
          var currentX = targetX, currentY = targetY;
          var lastMoveTime = 0;
          var velocityX = 0;
          var raf;
          var seen = false;

          window.addEventListener('mousemove', function(e) {
            // Offset the peach slightly down-right of the cursor so it doesn't overlap
            targetX = e.clientX + 18;
            targetY = e.clientY + 18;
            if (!seen) {
              peach.classList.add('is-visible');
              seen = true;
            }
            lastMoveTime = Date.now();
          }, { passive: true });

          window.addEventListener('mouseleave', function() {
            peach.classList.remove('is-visible');
          });
          window.addEventListener('mouseenter', function() {
            if (seen) peach.classList.add('is-visible');
          });

          // Add subtle hover-grow when over interactive elements
          document.addEventListener('mouseover', function(e) {
            var t = e.target;
            if (t.closest && t.closest('a, button, [role="button"], input[type="submit"], .b-pdp__thumb')) {
              peach.classList.add('is-hovering');
            }
          });
          document.addEventListener('mouseout', function(e) {
            var t = e.target;
            if (t.closest && t.closest('a, button, [role="button"], input[type="submit"], .b-pdp__thumb')) {
              peach.classList.remove('is-hovering');
            }
          });

          function tick() {
            // Lerp toward target with easing — gives the playful trail effect
            var dx = targetX - currentX;
            var dy = targetY - currentY;
            currentX += dx * 0.18;
            currentY += dy * 0.18;
            velocityX = dx;
            // Subtle rotation based on horizontal velocity (wobble as it moves)
            var rot = Math.max(-15, Math.min(15, velocityX * 0.4));
            peach.style.setProperty('--peach-rot', rot + 'deg');
            peach.style.left = currentX + 'px';
            peach.style.top = currentY + 'px';
            raf = requestAnimationFrame(tick);
          }
          tick();
        }

        // MOBILE MENU
        var mobileMenu = document.getElementById('beckyMobileMenu');
        var mobileOverlay = document.getElementById('beckyMobileOverlay');
        var mobileToggle = document.getElementById('beckyMobileToggle');
        var mobileClose = document.getElementById('beckyMobileClose');
        function openMobile() {
          if (mobileMenu) { mobileMenu.classList.add('is-open'); mobileMenu.setAttribute('aria-hidden','false'); }
          if (mobileOverlay) mobileOverlay.classList.add('is-open');
          document.body.style.overflow = 'hidden';
        }
        function closeMobile() {
          if (mobileMenu) { mobileMenu.classList.remove('is-open'); mobileMenu.setAttribute('aria-hidden','true'); }
          if (mobileOverlay) mobileOverlay.classList.remove('is-open');
          document.body.style.overflow = '';
        }
        if (mobileToggle) mobileToggle.addEventListener('click', openMobile);
        if (mobileClose) mobileClose.addEventListener('click', closeMobile);
        if (mobileOverlay) mobileOverlay.addEventListener('click', closeMobile);

        // CART DRAWER
        var drawer = document.getElementById('beckyCartDrawer');
        var overlay = document.getElementById('beckyCartOverlay');
        var openBtn = document.getElementById('beckyCartBtn');
        var closeBtn = document.getElementById('beckyCartClose');
        var cartCountEl = document.getElementById('beckyCartCount');
        var cartBody = document.getElementById('beckyCartBody');

        function openCart() {
          drawer.classList.add('is-open');
          overlay.classList.add('is-open');
          drawer.setAttribute('aria-hidden','false');
          document.body.style.overflow = 'hidden';
          refreshCart();
        }
        function closeCart() {
          drawer.classList.remove('is-open');
          overlay.classList.remove('is-open');
          drawer.setAttribute('aria-hidden','true');
          document.body.style.overflow = '';
        }
        function money(cents){ return '$' + (cents/100).toFixed(2); }

        function refreshCart() {
          fetch('/cart.js', {headers:{'Accept':'application/json'}})
            .then(r => r.json())
            .then(cart => {
              if (cartCountEl) {
                cartCountEl.textContent = cart.item_count;
                if (cart.item_count > 0) cartCountEl.removeAttribute('hidden');
                else cartCountEl.setAttribute('hidden','');
              }
              if (cart.item_count === 0) {
                cartBody.innerHTML = '<div class="becky-cart-empty"><p style="font-size:48px;margin:0 0 8px;">🍑</p><h4>Your cart is empty</h4><p style="color:#666;font-size:14px;margin:0 0 24px;">Add a Booty Scrub to get started.</p><a href="/products/booty-scrub" class="becky-btn becky-btn-primary" style="width:100%;">Shop the Scrub →</a></div>';
                var shipTopEl0 = document.getElementById('beckyCartShipTop');
                if (shipTopEl0) shipTopEl0.innerHTML = '';
                return;
              }
              var html = '';
              cart.items.forEach(function(item) {
                var img = item.image ? '<img src="'+item.image+'" alt="'+item.title+'" loading="lazy">' : '🍑';
                html += '<div class="becky-cart-item" data-key="'+item.key+'"><div class="becky-cart-item__img">'+img+'</div><div><p class="becky-cart-item__title">'+item.product_title+'</p><div class="becky-cart-item__price">'+money(item.final_price)+'</div><div class="becky-cart-item__qty"><button type="button" data-action="dec">−</button><span>'+item.quantity+'</span><button type="button" data-action="inc">+</button></div><button type="button" class="becky-cart-item__remove" data-action="remove">Remove</button></div></div>';
              });
              var THRESHOLD = 3500;
              var freeShipMet = cart.total_price >= THRESHOLD;
              var pct = Math.min(100, Math.round((cart.total_price / THRESHOLD) * 100));
              var remaining = THRESHOLD - cart.total_price;
              var shipLabel;
              if (freeShipMet) {
                shipLabel = '<span class="succ">🎉 You unlocked free shipping!</span>';
              } else {
                shipLabel = '<span>Add <strong>' + money(remaining) + '</strong> for free shipping</span><span class="pct">' + pct + '%</span>';
              }
              // Render free-ship bar at TOP of drawer
              var shipTopEl = document.getElementById('beckyCartShipTop');
              if (shipTopEl) {
                shipTopEl.innerHTML = '<div class="becky-cart-ship">' +
                  '<div class="becky-cart-ship__label">' + shipLabel + '</div>' +
                  '<div class="becky-cart-ship__track"><div class="becky-cart-ship__fill' + (freeShipMet ? ' is-full' : '') + '" style="width:' + pct + '%"></div><span class="becky-cart-ship__truck" style="left:calc(' + pct + '% - 8px);">🚚</span></div>' +
                  '</div>';
              }
              var trustRow = '<div class="becky-cart-trust"><span>30-day money-back</span><span>1% to EMC</span><span>Vegan</span></div>';
              html += '<div class="becky-cart-foot">' +
                '<p class="becky-cart-subtotal"><span>Subtotal</span><strong>' + money(cart.total_price) + '</strong></p>' +
                '<a href="/checkout" class="becky-cart-checkout">Checkout</a>' +
                trustRow +
                '</div>';
              cartBody.innerHTML = html;

              // Wire up qty + remove buttons
              cartBody.querySelectorAll('.becky-cart-item').forEach(function(itemEl){
                var key = itemEl.dataset.key;
                var item = cart.items.find(function(i){ return i.key === key; });
                itemEl.querySelectorAll('[data-action]').forEach(function(btn){
                  btn.addEventListener('click', function(){
                    var action = btn.dataset.action;
                    var newQty = action === 'remove' ? 0 : (action === 'inc' ? item.quantity + 1 : item.quantity - 1);
                    fetch('/cart/change.js', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({id:key, quantity:newQty})})
                      .then(function(){ refreshCart(); });
                  });
                });
              });
            });
        }

        if (openBtn) openBtn.addEventListener('click', openCart);
        if (closeBtn) closeBtn.addEventListener('click', closeCart);
        if (overlay) overlay.addEventListener('click', closeCart);
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape') { closeCart(); closeMobile(); } });

        // Intercept any form with action="/cart/add"
        document.addEventListener('submit', function(e){
          var form = e.target;
          if (form.action && form.action.indexOf('/cart/add') !== -1) {
            e.preventDefault();
            var data = new FormData(form);
            var submitBtn = form.querySelector('[type="submit"]');
            var origText = submitBtn ? submitBtn.innerHTML : '';
            if (submitBtn) submitBtn.innerHTML = 'Adding...';
            fetch('/cart/add.js', {method:'POST', body:data, headers:{'Accept':'application/json'}})
              .then(function(r){ return r.json(); })
              .then(function(){
                if (submitBtn) submitBtn.innerHTML = 'Added ✓';
                setTimeout(function(){
                  if (submitBtn) submitBtn.innerHTML = origText;
                }, 1500);
                openCart();
              })
              .catch(function(){
                if (submitBtn) submitBtn.innerHTML = origText;
                alert('Could not add to cart. Please try again.');
              });
          }
        });

        // Initial cart count refresh
        refreshCart();
      })();
    </script>
  </body>
</html>
