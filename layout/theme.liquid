    <noscript><img height="1" width="1" style="display:none;" alt="" src="https://ct.pinterest.com/v3/?event=init&tid=YOUR_PINTEREST_TAG_ID&noscript=1"/></noscript>
    {%- endcomment -%}

    {%- comment -%} === MICROSOFT CLARITY (free heatmaps + session recordings) === {%- endcomment -%}
    {%- comment -%}
    <script>
      (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y)})(window, document, "clarity", "script", "YOUR_CLARITY_PROJECT_ID");
