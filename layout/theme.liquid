<!doctype html>
<html lang="{{ request.locale.iso_code }}"{% if request.design_mode %} class="shopify-design-mode"{% endif %}>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#ff3465">
    <meta name="apple-mobile-web-app-title" content="Becky">
    <meta name="application-name" content="Becky">
    <meta name="msapplication-TileColor" content="#ff3465">

    {%- comment -%} FAVICON SYSTEM — covers every browser, OS, bookmarking surface {%- endcomment -%}
    <link rel="icon" type="image/png" sizes="16x16" href="{{ 'becky-favicon-16.png' | asset_url }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ 'becky-favicon-32.png' | asset_url }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ 'becky-apple-touch.png' | asset_url }}">
    <link rel="icon" type="image/png" sizes="192x192" href="{{ 'becky-android-192.png' | asset_url }}">
    <link rel="icon" type="image/png" sizes="512x512" href="{{ 'becky-android-512.png' | asset_url }}">
    <link rel="mask-icon" href="{{ 'becky-safari-pinned.svg' | asset_url }}" color="#ff3465">
    <link rel="shortcut icon" href="{{ 'becky-favicon-32.png' | asset_url }}" type="image/png">
    <link rel="manifest" href="{{ 'becky-manifest.json' | asset_url }}">

    <title>{{ page_title }}{% if current_tags %} – {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} – Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
    {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}

    {%- comment -%} OPEN GRAPH + TWITTER CARD — social link previews {%- endcomment -%}
    {%- liquid
      assign og_image = 'becky-og.png' | asset_url
      assign og_title = page_title
      assign og_description = page_description | default: shop.description | default: 'Walnut shell + rosehip exfoliant for buttne, KP, ingrowns, and dark spots. The skin no one talks about deserves a routine.'
      if template contains 'product' and product
        assign og_title = product.title | append: ' — Becky'
        if product.featured_image
          assign og_image = product.featured_image | image_url: width: 1200
        endif
        assign og_description = product.description | strip_html | truncate: 200
      endif
      if template contains 'article' and article
        assign og_title = article.title | append: ' — Becky'
        if article.image
          assign og_image = article.image | image_url: width: 1200
        endif
        assign og_description = article.metafields.becky.tldr | default: article.excerpt | default: article.content | strip_html | truncate: 200
      endif
    -%}
    <meta property="og:type" content="{% if template contains 'article' %}article{% elsif template contains 'product' %}product{% else %}website{% endif %}">
    <meta property="og:title" content="{{ og_title | escape }}">
    <meta property="og:description" content="{{ og_description | escape }}">
    <meta property="og:image" content="{{ og_image }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:site_name" content="Becky">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ og_title | escape }}">
    <meta name="twitter:description" content="{{ og_description | escape }}">
    <meta name="twitter:image" content="{{ og_image }}">
    <meta name="twitter:site" content="@hibecky">
    <link rel="canonical" href="{{ canonical_url }}">

    {% render 'meta-tags' %}
    {% render 'schema-json-ld' %}
    {%- if request.page_type == 'product' and product.metafields.becky.faq_entries != blank -%}
      {% render 'faq-schema-json-ld', faq_entries: product.metafields.becky.faq_entries.value %}
    {%- endif -%}
    {%- if request.page_type == 'article' and article.metafields.becky.faq_entries != blank -%}
      {% render 'faq-schema-json-ld', faq_entries: article.metafields.becky.faq_entries.value %}
    {%- endif -%}
    {%- if request.page_type == 'page' and page.metafields.becky.faq_entries != blank -%}
      {% render 'faq-schema-json-ld', faq_entries: page.metafields.becky.faq_entries.value %}
    {%- endif -%}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet">

    {%- comment -%} Junip review widget {%- endcomment -%}
    <script src="https://static.juniphq.com/v1/widget.js" defer></script>

    {%- comment -%}
      ═══════════════════════════════════════════════════════════════════════
      TRACKING PIXEL SCAFFOLDING — replace the placeholder IDs with your real
      IDs, push to GitHub, and Shopify syncs in ~30 seconds. Comment out any
      pixel you don't use yet.

      WHERE TO GET EACH ID:
      • GA4: analytics.google.com → Admin → Property → "Data streams"
      • Facebook Pixel: business.facebook.com → Events Manager → Pixels
      • TikTok Pixel: ads.tiktok.com → Assets → Events → Web Events
      • Pinterest Tag: ads.pinterest.com → Conversions → Pinterest Tag
      • Microsoft Clarity: clarity.microsoft.com → Settings → Setup
      • Google Search Console: search.google.com/search-console → Property
        → Settings → "Ownership verification" → HTML tag method
      ═══════════════════════════════════════════════════════════════════════
    {%- endcomment -%}

    {%- comment -%} === GOOGLE ANALYTICS 4 === {%- endcomment -%}
    {%- comment -%}
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
    {%- endcomment -%}

    {%- comment -%} === META (FACEBOOK + INSTAGRAM) PIXEL === {%- endcomment -%}
    {%- comment -%}
    <script>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', 'YOUR_PIXEL_ID');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=YOUR_PIXEL_ID&ev=PageView&noscript=1"/></noscript>
    {%- endcomment -%}

