<!doctype html>
<html lang="{{ request.locale.iso_code }}"{% if request.design_mode %} class="shopify-design-mode"{% endif %}>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#ff3465">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ page_title }}{% if current_tags %} – {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} – Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
    {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}

    {% render 'meta-tags' %}
    {% render 'schema-json-ld' %}
    {%- if request.page_type == 'product' and product.metafields.becky.faq_entries != blank -%}
      {% render 'faq-schema-json-ld', faq_entries: product.metafields.becky.faq_entries.value %}
    {%- endif -%}
    {%- if request.page_type == 'article' and article.metafields.becky.faq_entries != blank -%}
      {% render 'faq-schema-json-ld', faq_entries: article.metafields.becky.faq_entries.value %}
    {%- endif -%}
    {%- if request.page_type == 'page' and page.metafields.becky.faq_entries != blank -%}
      {% render 'faq-schema-json-ld', faq_entries: page.metafields.becky.faq_entries.value %}
    {%- endif -%}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet">

    {%- comment -%} Junip review widget {%- endcomment -%}
    <script src="https://static.juniphq.com/v1/widget.js" defer></script>

    {{ content_for_header }}

    <style>
      :root {
        --becky-pink: #ff3465;
        --becky-pink-dark: #d12950;
        --becky-blush: #ffebeb;
        --becky-peach: #fddbd1;
        --becky-lavender: #f3e5fe;
        --becky-yellow: #fde300;
        --becky-ink: #1a1a1a;
        --becky-grey: #4a4a4a;
        --becky-light: #f7f7f8;
        --becky-border: #e8e8eb;
      }
      *, *::before, *::after { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body { margin: 0; font-family: 'Work Sans', system-ui, -apple-system, sans-serif; color: var(--becky-ink); background: #fff; line-height: 1.5; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
      h1, h2, h3, h4, h5, h6 { font-family: 'Poppins', 'Work Sans', sans-serif; font-weight: 700; line-height: 1.15; margin: 0; text-wrap: balance; letter-spacing: -0.01em; }
      a { color: inherit; text-decoration: none; transition: color 160ms ease; }
      img { max-width: 100%; height: auto; display: block; }
      button { font-family: inherit; cursor: pointer; }

      /* HEADER */
      .becky-header { position: sticky; top: 0; z-index: 100; background: #fff; border-bottom: 1px solid var(--becky-border); transition: box-shadow 200ms ease; }
      .becky-header.is-scrolled { box-shadow: 0 4px 20px rgba(0,0,0,0.04); }
      .becky-header__bar { max-width: 1280px; margin: 0 auto; padding: 16px 24px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 24px; }
      .becky-header__logo { display: inline-flex; align-items: center; gap: 8px; justify-self: start; }
      .becky-header__logo svg { height: 36px; width: auto; display: block; }
      .becky-header__nav { display: flex; gap: 28px; justify-self: center; }
      .becky-header__nav a { font-weight: 600; font-size: 15px; color: var(--becky-ink); position: relative; padding: 4px 0; }
      .becky-header__nav a:hover { color: var(--becky-pink); }
      .becky-header__nav a.active::after { content: ''; position: absolute; left: 0; right: 0; bottom: -4px; height: 2px; background: var(--becky-pink); border-radius: 2px; }
      .becky-header__actions { display: flex; gap: 12px; align-items: center; justify-self: end; }
      .becky-header__icon { background: none; border: none; padding: 8px; color: var(--becky-ink); display: inline-flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 600; }
      .becky-header__icon:hover { color: var(--becky-pink); }
      .becky-cart-count { background: var(--becky-pink); color: #fff; font-size: 11px; font-weight: 700; padding: 2px 6px; border-radius: 999px; min-width: 18px; text-align: center; }
      @media (max-width: 820px) {
        .becky-header__nav { display: none; }
        .becky-header__bar { grid-template-columns: 1fr auto; }
        .becky-header__logo svg { height: 28px; }
      }

      /* ANNOUNCEMENT BAR */
      .becky-announce { background: var(--becky-ink); color: #fff; padding: 8px 24px; text-align: center; font-size: 13px; font-weight: 500; }
      .becky-announce strong { color: var(--becky-yellow); font-weight: 700; }

      /* BUTTONS */
      .becky-btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 14px 28px; border-radius: 999px; font-weight: 700; font-size: 16px; transition: all 160ms ease; border: 2px solid transparent; cursor: pointer; font-family: inherit; text-decoration: none; }
      .becky-btn-primary { background: var(--becky-pink); color: #fff; border-color: var(--becky-pink); }
      .becky-btn-primary:hover { background: var(--becky-pink-dark); border-color: var(--becky-pink-dark); transform: translateY(-1px); box-shadow: 0 8px 20px rgba(255,52,101,0.25); }
      .becky-btn-secondary { background: transparent; color: var(--becky-ink); border-color: var(--becky-ink); }
      .becky-btn-secondary:hover { background: var(--becky-ink); color: #fff; }
      .becky-btn-yellow { background: var(--becky-yellow); color: var(--becky-ink); border-color: var(--becky-yellow); }
      .becky-btn-yellow:hover { background: #f0d600; border-color: #f0d600; }

      /* MINIMAL FOOTER (Buttface-inspired) */
      .becky-footer { background: var(--becky-ink); color: #fff; padding: 96px 24px 0; margin-top: 120px; overflow: hidden; }
      .becky-footer__top { max-width: 920px; margin: 0 auto; text-align: center; padding: 0 0 80px; }
      .becky-footer__eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--becky-yellow); font-weight: 700; margin: 0 0 20px; }
      .becky-footer__pitch { font-family: 'Poppins', sans-serif; font-weight: 700; font-size: clamp(28px, 4vw, 44px); line-height: 1.1; margin: 0 0 32px; letter-spacing: -0.02em; }
      .becky-footer__pitch em { color: var(--becky-pink); font-style: normal; }
      .becky-footer__form { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; max-width: 520px; margin: 0 auto; }
      .becky-footer__form input { flex: 1; min-width: 280px; padding: 18px 24px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.05); color: #fff; font-size: 16px; font-family: inherit; }
      .becky-footer__form input::placeholder { color: rgba(255,255,255,0.5); }
      .becky-footer__form input:focus { outline: none; border-color: var(--becky-pink); background: rgba(255,255,255,0.08); }
      .becky-footer__form button { padding: 18px 32px; background: var(--becky-pink); color: #fff; border: none; border-radius: 999px; font-weight: 700; font-size: 16px; cursor: pointer; font-family: inherit; transition: background 200ms ease; }
      .becky-footer__form button:hover { background: var(--becky-pink-dark); }
      .becky-footer__small-links { display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; margin: 40px 0 0; font-size: 13px; }
      .becky-footer__small-links a { color: rgba(255,255,255,0.6); transition: color 200ms ease; }
      .becky-footer__small-links a:hover { color: #fff; }
      .becky-footer__wordmark { display: flex; align-items: center; justify-content: center; padding: 0 24px; margin: 0; line-height: 0.85; }
      .becky-footer__wordmark svg { width: 100%; max-width: 1400px; height: auto; display: block; }
      .becky-footer__copyright { max-width: 1280px; margin: 0 auto; padding: 32px 0 28px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; font-size: 12px; color: rgba(255,255,255,0.4); }

      /* PAGE CONTAINER */
      .becky-page-shell { min-height: 60vh; }
    </style>
  </head>

  <body class="becky-body">

    <!-- ANNOUNCEMENT BAR -->
    <div class="becky-announce">
      Free US shipping over $35 · <strong>1% of every order goes to Every Mother Counts</strong>
    </div>

    <!-- HEADER -->
    <header class="becky-header" id="beckyHeader">
      <div class="becky-header__bar">
        <a href="/" class="becky-header__logo" aria-label="Becky home">
          {% comment %} Inline SVG logo so it ALWAYS renders {% endcomment %}
          <svg viewBox="0 0 360 80" role="img" aria-label="Becky" style="height: 36px; width: auto;">
            <text x="4" y="62" style="font: 700 64px 'Poppins', 'Work Sans', sans-serif; fill: #ff3465; letter-spacing: -2px;">becky</text>
            <circle cx="245" cy="20" r="9" style="fill: #fde300;"/>
          </svg>
        </a>

        <nav class="becky-header__nav" aria-label="Main">
          <a href="/products/booty-scrub"{% if template contains 'product' %} class="active"{% endif %}>Shop</a>
          <a href="/pages/routine"{% if page.handle == 'routine' %} class="active"{% endif %}>Routine</a>
          <a href="/blogs/booty-atlas"{% if template contains 'blog' or template contains 'article' %} class="active"{% endif %}>The Atlas</a>
          <a href="/pages/reviews"{% if page.handle == 'reviews' %} class="active"{% endif %}>Reviews</a>
          <a href="/pages/faq"{% if page.handle == 'faq' %} class="active"{% endif %}>FAQ</a>
          <a href="/pages/our-story"{% if page.handle == 'our-story' %} class="active"{% endif %}>About</a>
        </nav>

        <div class="becky-header__actions">
          <a href="/search" class="becky-header__icon" aria-label="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </a>
          <button type="button" class="becky-header__icon" id="beckyCartBtn" aria-label="Open cart">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="becky-cart-count" id="beckyCartCount"{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
          </button>
        </div>
      </div>
    </header>

    <main id="MainContent" class="becky-page-shell">
      {{ content_for_layout }}
    </main>

    <!-- MINIMAL FOOTER -->
    <footer class="becky-footer">
      <div class="becky-footer__top">
        <p class="becky-footer__eyebrow">Can we touch your butt?</p>
        <h2 class="becky-footer__pitch">Smoother skin, real talk, <em>10% off</em> your first order.</h2>
        {%- form 'customer', class: 'becky-footer__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter,footer">
          <input type="email" name="contact[email]" placeholder="your@email.com" required>
          <button type="submit">Subscribe</button>
        {%- endform -%}
        <div class="becky-footer__small-links">
          <a href="/pages/our-story">About</a>
          <a href="/pages/faq">FAQ</a>
          <a href="/policies/refund-policy">Returns</a>
          <a href="/policies/shipping-policy">Shipping</a>
          <a href="/policies/privacy-policy">Privacy</a>
          <a href="/policies/terms-of-service">Terms</a>
          <a href="https://instagram.com/hibecky" target="_blank" rel="noopener">Instagram</a>
          <a href="https://tiktok.com/@hibecky" target="_blank" rel="noopener">TikTok</a>
          <a href="mailto:hi@hibecky.com">Email</a>
        </div>
      </div>

      <!-- MASSIVE WORDMARK -->
      <div class="becky-footer__wordmark" aria-hidden="true">
        <svg viewBox="0 0 1000 240" xmlns="http://www.w3.org/2000/svg">
          <text x="0" y="200" style="font: 800 240px 'Poppins', 'Work Sans', sans-serif; fill: #ffffff; letter-spacing: -12px;">becky</text>
          <circle cx="755" cy="62" r="28" style="fill: #fde300;"/>
        </svg>
      </div>

      <div class="becky-footer__copyright">
        <span>© {{ 'now' | date: '%Y' }} Becky · Made small-batch in the USA · 1% to <a href="https://everymothercounts.org" target="_blank" rel="noopener" style="color: rgba(255,255,255,0.5);">Every Mother Counts</a></span>
      </div>
    </footer>

    <!-- SLIDE-IN CART DRAWER -->
    <div class="becky-cart-overlay" id="beckyCartOverlay"></div>
    <aside class="becky-cart-drawer" id="beckyCartDrawer" aria-label="Shopping cart" aria-hidden="true">
      <div class="becky-cart-head">
        <h3>Your cart</h3>
        <button type="button" class="becky-cart-close" id="beckyCartClose" aria-label="Close cart">×</button>
      </div>
      <div class="becky-cart-body" id="beckyCartBody">
        <div class="becky-cart-empty">
          <p style="font-size:48px;margin:0 0 8px;">🍑</p>
          <h4>Your cart is empty</h4>
          <p style="color:var(--becky-grey);font-size:14px;margin:0 0 24px;">Add a Booty Scrub to get started.</p>
          <a href="/products/booty-scrub" class="becky-btn becky-btn-primary" style="width:100%;">Shop the Scrub →</a>
        </div>
      </div>
    </aside>

    <style>
      .becky-cart-overlay { position:fixed; inset:0; background:rgba(26,26,26,0.5); opacity:0; pointer-events:none; transition:opacity 200ms ease; z-index:200; }
      .becky-cart-overlay.is-open { opacity:1; pointer-events:auto; }
      .becky-cart-drawer { position:fixed; top:0; right:0; bottom:0; width:100%; max-width:440px; background:#fff; transform:translateX(100%); transition:transform 280ms cubic-bezier(0.4,0,0.2,1); z-index:201; display:flex; flex-direction:column; box-shadow:-12px 0 32px rgba(0,0,0,0.08); }
      .becky-cart-drawer.is-open { transform:translateX(0); }
      .becky-cart-head { display:flex; align-items:center; justify-content:space-between; padding:20px 24px; border-bottom:1px solid var(--becky-border); }
      .becky-cart-head h3 { font-size:20px; margin:0; }
      .becky-cart-close { background:none; border:none; font-size:32px; line-height:1; color:var(--becky-ink); cursor:pointer; padding:0 8px; }
      .becky-cart-close:hover { color:var(--becky-pink); }
      .becky-cart-body { flex:1; overflow-y:auto; padding:24px; }
      .becky-cart-empty { text-align:center; padding:48px 0; }
      .becky-cart-empty h4 { font-size:18px; margin:0 0 8px; }
      .becky-cart-item { display:grid; grid-template-columns:80px 1fr auto; gap:16px; padding:20px 0; border-bottom:1px solid var(--becky-border); align-items:center; }
      .becky-cart-item__img { width:80px; height:80px; background:var(--becky-blush); border-radius:12px; overflow:hidden; display:flex; align-items:center; justify-content:center; }
      .becky-cart-item__img img { width:100%; height:100%; object-fit:cover; }
      .becky-cart-item__title { font-weight:600; font-size:15px; margin:0 0 6px; }
      .becky-cart-item__price { font-weight:700; color:var(--becky-pink); font-size:14px; }
      .becky-cart-item__qty { display:flex; align-items:center; gap:8px; margin-top:6px; }
      .becky-cart-item__qty button { width:24px; height:24px; border-radius:50%; border:1px solid var(--becky-border); background:#fff; cursor:pointer; font-size:14px; }
      .becky-cart-item__qty button:hover { border-color:var(--becky-pink); color:var(--becky-pink); }
      .becky-cart-item__qty span { min-width:24px; text-align:center; font-weight:600; }
      .becky-cart-item__remove { background:none; border:none; color:#999; cursor:pointer; font-size:11px; text-decoration:underline; padding:0; }
      .becky-cart-foot { border-top:1px solid var(--becky-border); padding:20px 24px; background:#fff; }
      .becky-cart-subtotal { display:flex; justify-content:space-between; align-items:baseline; margin:0 0 4px; }
      .becky-cart-subtotal strong { font-family:'Poppins',sans-serif; font-size:20px; font-weight:700; }
      .becky-cart-shipnote { font-size:13px; color:var(--becky-grey); margin:0 0 16px; }
      .becky-cart-checkout { display:block; width:100%; padding:16px; background:var(--becky-pink); color:#fff !important; border:none; border-radius:999px; font-weight:700; font-size:16px; text-align:center; text-decoration:none; font-family:inherit; cursor:pointer; transition:background 200ms ease; }
      .becky-cart-checkout:hover { background:var(--becky-pink-dark); }
      .becky-cart-trust { display:flex; gap:8px; justify-content:center; margin:12px 0 0; font-size:11px; color:#999; flex-wrap:wrap; }
    </style>

    <script>
      (function() {
        var header = document.getElementById('beckyHeader');
        if (header) {
          window.addEventListener('scroll', function() {
            if (window.scrollY > 8) header.classList.add('is-scrolled');
            else header.classList.remove('is-scrolled');
          }, { passive: true });
        }

        // CART DRAWER
        var drawer = document.getElementById('beckyCartDrawer');
        var overlay = document.getElementById('beckyCartOverlay');
        var openBtn = document.getElementById('beckyCartBtn');
        var closeBtn = document.getElementById('beckyCartClose');
        var cartCountEl = document.getElementById('beckyCartCount');
        var cartBody = document.getElementById('beckyCartBody');

        function openCart() {
          drawer.classList.add('is-open');
          overlay.classList.add('is-open');
          drawer.setAttribute('aria-hidden','false');
          document.body.style.overflow = 'hidden';
          refreshCart();
        }
        function closeCart() {
          drawer.classList.remove('is-open');
          overlay.classList.remove('is-open');
          drawer.setAttribute('aria-hidden','true');
          document.body.style.overflow = '';
        }
        function money(cents){ return '$' + (cents/100).toFixed(2); }

        function refreshCart() {
          fetch('/cart.js', {headers:{'Accept':'application/json'}})
            .then(r => r.json())
            .then(cart => {
              if (cartCountEl) {
                cartCountEl.textContent = cart.item_count;
                if (cart.item_count > 0) cartCountEl.removeAttribute('hidden');
                else cartCountEl.setAttribute('hidden','');
              }
              if (cart.item_count === 0) {
                cartBody.innerHTML = '<div class="becky-cart-empty"><p style="font-size:48px;margin:0 0 8px;">🍑</p><h4>Your cart is empty</h4><p style="color:#666;font-size:14px;margin:0 0 24px;">Add a Booty Scrub to get started.</p><a href="/products/booty-scrub" class="becky-btn becky-btn-primary" style="width:100%;">Shop the Scrub →</a></div>';
                return;
              }
              var html = '';
              cart.items.forEach(function(item) {
                var img = item.image ? '<img src="'+item.image+'" alt="'+item.title+'" loading="lazy">' : '🍑';
                html += '<div class="becky-cart-item" data-key="'+item.key+'"><div class="becky-cart-item__img">'+img+'</div><div><p class="becky-cart-item__title">'+item.product_title+'</p><div class="becky-cart-item__price">'+money(item.final_price)+'</div><div class="becky-cart-item__qty"><button type="button" data-action="dec">−</button><span>'+item.quantity+'</span><button type="button" data-action="inc">+</button></div><button type="button" class="becky-cart-item__remove" data-action="remove">Remove</button></div></div>';
              });
              var freeShipMet = cart.total_price >= 3500;
              var shipNote = freeShipMet ? '✅ You qualify for free shipping' : '🚚 Add ' + money(3500 - cart.total_price) + ' for free shipping';
              html += '<div class="becky-cart-foot"><p class="becky-cart-subtotal"><span>Subtotal</span><strong>'+money(cart.total_price)+'</strong></p><p class="becky-cart-shipnote">'+shipNote+'</p><a href="/checkout" class="becky-cart-checkout">Checkout →</a><p class="becky-cart-trust">30-day money-back · 1% to EMC · Vegan</p></div>';
              cartBody.innerHTML = html;

              // Wire up qty + remove buttons
              cartBody.querySelectorAll('.becky-cart-item').forEach(function(itemEl){
                var key = itemEl.dataset.key;
                var item = cart.items.find(function(i){ return i.key === key; });
                itemEl.querySelectorAll('[data-action]').forEach(function(btn){
                  btn.addEventListener('click', function(){
                    var action = btn.dataset.action;
                    var newQty = action === 'remove' ? 0 : (action === 'inc' ? item.quantity + 1 : item.quantity - 1);
                    fetch('/cart/change.js', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({id:key, quantity:newQty})})
                      .then(function(){ refreshCart(); });
                  });
                });
              });
            });
        }

        if (openBtn) openBtn.addEventListener('click', openCart);
        if (closeBtn) closeBtn.addEventListener('click', closeCart);
        if (overlay) overlay.addEventListener('click', closeCart);
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape') closeCart(); });

        // Intercept any form with action="/cart/add"
        document.addEventListener('submit', function(e){
          var form = e.target;
          if (form.action && form.action.indexOf('/cart/add') !== -1) {
            e.preventDefault();
            var data = new FormData(form);
            var submitBtn = form.querySelector('[type="submit"]');
            var origText = submitBtn ? submitBtn.innerHTML : '';
            if (submitBtn) submitBtn.innerHTML = 'Adding...';
            fetch('/cart/add.js', {method:'POST', body:data, headers:{'Accept':'application/json'}})
              .then(function(r){ return r.json(); })
              .then(function(){
                if (submitBtn) submitBtn.innerHTML = 'Added ✓';
                setTimeout(function(){
                  if (submitBtn) submitBtn.innerHTML = origText;
                }, 1500);
                openCart();
              })
              .catch(function(){
                if (submitBtn) submitBtn.innerHTML = origText;
                alert('Could not add to cart. Please try again.');
              });
          }
        });

        // Initial cart count refresh
        refreshCart();
      })();
    </script>
  </body>
</html>
