{%- comment -%}
  Becky pixel peach — reusable 8-bit pixel art peach
  Usage: {% render 'becky-pixel-peach', size: 64 %}
  Optional `class` parameter for additional styling.
{%- endcomment -%}
{%- assign size = size | default: 48 -%}
<img src="{{ 'becky-pixel-peach.svg' | asset_url }}" alt="" role="presentation" width="{{ size }}" height="{{ size }}" style="width:{{ size }}px;height:{{ size }}px;image-rendering:pixelated;image-rendering:crisp-edges;{% if class %}{% endif %}" {% if class %}class="{{ class }}"{% endif %}>
