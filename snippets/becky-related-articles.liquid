{%- comment -%}
  Becky Related Articles strip
  --------------------------------------------------------------
  Renders a "Read Next" component from a JSON metafield containing an
  array of article handles. Each handle is looked up in the booty-atlas
  blog and rendered as a card.

  Usage:
    {% render 'becky-related-articles',
       handles: article.metafields.becky.related_articles.value,
       heading: 'Read Next' %}

    {% render 'becky-related-articles',
       handles: product.metafields.becky.related_articles.value,
       heading: 'From The Booty Atlas',
       blog_handle: 'booty-atlas' %}

  Input shape (becky.related_articles metafield, type: json):
    ["butt-skincare-routine", "keratosis-pilaris-on-the-butt", ...]
{%- endcomment -%}

{%- liquid
  assign blog_handle = blog_handle | default: 'booty-atlas'
  assign heading = heading | default: 'Read Next'
  assign target_blog = blogs[blog_handle]
  assign has_articles = false
  if handles != blank and handles.size > 0
    assign has_articles = true
  endif
-%}

{%- if has_articles and target_blog != blank -%}
  <section class="becky-related-articles" aria-label="{{ heading }}" style="padding: 48px 24px; background: rgb(var(--color-background, 255 255 255));">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h2 style="font-family: var(--font-primary--family); font-weight: 700; font-size: 28px; line-height: 1.1; margin: 0 0 32px 0; color: var(--color-foreground-heading);">
        {{ heading }}
      </h2>
      <div class="becky-related-articles__grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px;">
        {%- for handle in handles limit: 6 -%}
          {%- assign target_article = target_blog.articles | where: 'handle', handle | first -%}
          {%- if target_article -%}
            <a href="{{ target_article.url }}" class="becky-related-articles__card" style="display: flex; flex-direction: column; gap: 12px; text-decoration: none; color: inherit; transition: transform 200ms ease;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
              {%- if target_article.image -%}
                <div style="aspect-ratio: 4 / 3; overflow: hidden; border-radius: 8px; background: #f5f5f5;">
                  <img
                    src="{{ target_article.image | image_url: width: 600 }}"
                    alt="{{ target_article.image.alt | escape | default: target_article.title | escape }}"
                    loading="lazy"
                    width="600"
                    height="450"
                    style="width: 100%; height: 100%; object-fit: cover; display: block;"
                  >
                </div>
              {%- else -%}
                <div style="aspect-ratio: 4 / 3; border-radius: 8px; background: linear-gradient(135deg, #ffebeb 0%, #fddbd1 100%); display: flex; align-items: center; justify-content: center;">
                  <span aria-hidden="true" style="font-size: 48px;">🍑</span>
                </div>
              {%- endif -%}
              <div>
                {%- if target_article.metafields.becky.reading_time_min != blank -%}
                  <p style="font-family: var(--font-subheading--family, var(--font-body--family)); font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: rgb(105 114 123); margin: 0 0 6px 0;">
                    {{ target_article.metafields.becky.reading_time_min }} min read
                  </p>
                {%- endif -%}
                <h3 style="font-family: var(--font-primary--family); font-weight: 600; font-size: 18px; line-height: 1.3; margin: 0 0 8px 0; color: var(--color-foreground-heading); text-wrap: balance;">
                  {{ target_article.title }}
                </h3>
                {%- if target_article.metafields.becky.tldr != blank -%}
                  <p style="font-family: var(--font-body--family); font-size: 14px; line-height: 1.5; color: rgb(105 114 123); margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                    {{ target_article.metafields.becky.tldr | truncate: 180 }}
                  </p>
                {%- elsif target_article.excerpt != blank -%}
                  <p style="font-family: var(--font-body--family); font-size: 14px; line-height: 1.5; color: rgb(105 114 123); margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                    {{ target_article.excerpt | strip_html | truncate: 180 }}
                  </p>
                {%- endif -%}
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}
