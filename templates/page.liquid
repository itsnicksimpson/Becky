{%- comment -%}
  Becky page — polished v2 (Routine, FAQ, About, etc.)
{%- endcomment -%}

<style>
  .b-page-hero { background: linear-gradient(135deg, var(--becky-blush) 0%, var(--becky-lavender) 100%); padding: 80px 24px; text-align: center; }
  .b-page-hero__inner { max-width: 760px; margin: 0 auto; }
  .b-page-hero__eyebrow { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--becky-pink); font-weight: 700; margin: 0 0 16px; }
  .b-page-hero h1 { font-size: clamp(36px, 6vw, 64px); margin: 0 0 16px; line-height: 1.05; }
  .b-page-hero p { font-size: 18px; color: var(--becky-grey); max-width: 540px; margin: 0 auto; }

  .b-page { max-width: 760px; margin: 0 auto; padding: 64px 24px 48px; font-size: 17px; line-height: 1.7; color: #2a2a2a; }
  .b-page h2 { font-size: clamp(24px, 3.5vw, 32px); margin: 56px 0 20px; line-height: 1.15; }
  .b-page h3 { font-size: clamp(20px, 2.8vw, 24px); margin: 36px 0 14px; }
  .b-page h2:first-child, .b-page h3:first-child { margin-top: 0; }
  .b-page p { margin: 0 0 20px; }
  .b-page a { color: var(--becky-pink); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1.5px; }
  .b-page a:hover { color: var(--becky-pink-dark); }
  .b-page ul, .b-page ol { padding-left: 24px; margin: 0 0 24px; }
  .b-page li { margin: 0 0 12px; line-height: 1.65; }
  .b-page strong { color: var(--becky-ink); font-weight: 700; }
  .b-page em { color: var(--becky-pink); font-style: normal; font-weight: 600; }

  .b-page blockquote { border-left: 4px solid var(--becky-pink); padding: 20px 28px; margin: 32px 0; background: var(--becky-blush); border-radius: 0 16px 16px 0; font-size: 18px; color: var(--becky-ink); }
  .b-page blockquote p:last-child { margin: 0; }

  .b-page details { background: var(--becky-light); border-radius: 16px; padding: 0 24px; margin: 0 0 12px; transition: background 200ms ease; }
  .b-page details[open] { background: var(--becky-blush); }
  .b-page summary { padding: 20px 0; cursor: pointer; list-style: none; display: flex; justify-content: space-between; gap: 16px; font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 17px; line-height: 1.4; color: var(--becky-ink); }
  .b-page summary::-webkit-details-marker { display: none; }
  .b-page summary::after { content: '+'; font-size: 24px; font-weight: 400; line-height: 1; transition: transform 200ms ease; color: var(--becky-pink); flex-shrink: 0; }
  .b-page details[open] summary::after { transform: rotate(45deg); }
  .b-page details > div, .b-page details > p { padding: 0 0 24px; line-height: 1.65; color: var(--becky-grey); }

  /* Routine specifically — step cards */
  .b-page .routine-step { background: #fff; border: 1px solid var(--becky-border); border-radius: 20px; padding: 32px; margin: 20px 0; }
  .b-page .routine-step h3 { color: var(--becky-pink); margin-top: 0; }

  /* Inline CTA */
  .b-page-cta { background: var(--becky-pink); color: #fff; border-radius: 24px; padding: 40px; text-align: center; margin: 48px 0; }
  .b-page-cta h3 { color: #fff; margin: 0 0 12px; font-size: 24px; }
  .b-page-cta p { color: rgba(255,255,255,0.95); margin: 0 0 24px; }
  .b-page-cta .becky-btn { background: #fff; color: var(--becky-pink); border-color: #fff; }
  .b-page-cta .becky-btn:hover { background: var(--becky-yellow); color: var(--becky-ink); border-color: var(--becky-yellow); }

  /* Tables */
  .b-page table { width: 100%; border-collapse: collapse; margin: 24px 0; font-size: 15px; }
  .b-page th, .b-page td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--becky-border); }
  .b-page th { background: var(--becky-light); font-weight: 700; }
  .b-page tr:hover { background: var(--becky-blush); }
</style>

<div class="b-page-hero">
  <div class="b-page-hero__inner">
    {%- if page.handle == 'routine' -%}<p class="b-page-hero__eyebrow">The 3-Step Becky Routine</p>{%- endif -%}
    {%- if page.handle == 'faq' -%}<p class="b-page-hero__eyebrow">Frequently asked questions</p>{%- endif -%}
    {%- if page.handle == 'our-story' -%}<p class="b-page-hero__eyebrow">Our story</p>{%- endif -%}
    <h1>{{ page.title }}</h1>
    {%- if page.handle == 'routine' -%}<p>Four minutes, three times a week, four weeks. The protocol that takes your skin from bumpy and embarrassed to smooth and confident.</p>{%- endif -%}
    {%- if page.handle == 'faq' -%}<p>Everything we get asked about Becky, the Booty Scrub, ingredients, conditions, and how to actually use it.</p>{%- endif -%}
  </div>
</div>

<article class="b-page">
  {{ page.content }}

  {%- comment -%}Add inline CTA to all pages except those that already have one{%- endcomment -%}
  {%- unless page.content contains 'becky-btn-primary' or page.handle == 'cart' -%}
    <div class="b-page-cta">
      <h3>Ready to start your routine?</h3>
      <p>The Becky Booty Scrub — walnut shell + rosehip exfoliant, $20, ships free over $35.</p>
      <a href="/products/booty-scrub" class="becky-btn">Shop the Scrub →</a>
    </div>
  {%- endunless -%}
</article>
