{%- comment -%}
  Becky homepage v4 — COLORFUL + FUN + SOPHISTICATED
  Pink/yellow/peach/lavender brought back as section anchors
  Sticker badges, asymmetric layouts, playful copy
{%- endcomment -%}

{%- assign product = all_products['booty-scrub'] -%}
{%- assign featured_blog = blogs['booty-atlas'] -%}
{%- assign avg_rating = product.metafields.becky.rating_value | default: 4.7 -%}
{%- assign review_count = product.metafields.becky.review_count | default: 1247 -%}

<style>
  .v4 { width: 100%; --g: clamp(20px, 4vw, 64px); }
  .v4 p { margin: 0 0 16px; line-height: 1.6; }

  /* HERO — pink, big and fun */
  .v4-hero { padding: clamp(80px, 12vw, 140px) var(--g); background: linear-gradient(135deg, #ff3465 0%, #ff7a9a 50%, #ffb3c5 100%); position: relative; overflow: hidden; color: #fff; }
  .v4-hero__title, .v4-hero__sub { color: #fff !important; }
  .v4-hero::before { content: ''; position: absolute; width: 480px; height: 480px; background: #fff; border-radius: 50%; top: -120px; right: -120px; opacity: 0.10; }
  .v4-hero::after { content: '🍑'; position: absolute; font-size: 220px; left: -40px; bottom: -60px; opacity: 0.10; transform: rotate(-15deg); }
  .v4-hero__inner { max-width: 1320px; margin: 0 auto; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(40px, 6vw, 96px); align-items: center; position: relative; z-index: 1; }
  @media (max-width: 880px) { .v4-hero__inner { grid-template-columns: 1fr; gap: 48px; } }
  .v4-hero__pill { display: inline-flex; align-items: center; gap: 8px; padding: 10px 18px; background: #fff; color: var(--becky-pink); border-radius: 999px; font-size: 13px; font-weight: 800; letter-spacing: 0.04em; margin: 0 0 28px; }
  .v4-hero__pill img { width: 22px; height: 22px; image-rendering: pixelated; image-rendering: crisp-edges; }
  .v4-hero__title { font-size: clamp(48px, 8vw, 104px); line-height: 0.92; letter-spacing: -0.04em; margin: 0 0 32px; font-weight: 800; color: var(--becky-ink); }
  .v4-hero__title em { font-style: normal; color: var(--becky-pink); position: relative; display: inline-block; }
  .v4-hero__title em { color: #fff; text-decoration: underline; text-underline-offset: 6px; text-decoration-thickness: 4px; }
  .v4-hero__title em::after { display: none; }
  .v4-hero__sub { font-size: clamp(17px, 1.6vw, 21px); line-height: 1.5; color: rgba(255,255,255,0.95); max-width: 540px; margin: 0 0 40px; font-weight: 500; }
  .v4-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
  .v4-hero__btn-primary { background: #fff; color: var(--becky-pink) !important; border: 2px solid #fff; padding: 16px 32px; border-radius: 999px; font-weight: 800; transition: all 200ms ease; display: inline-flex; align-items: center; gap: 8px; }
  .v4-hero__btn-primary:hover { background: var(--becky-ink); border-color: var(--becky-ink); color: #fff !important; transform: translateY(-1px); }
  .v4-hero__small-text { font-size: 13px; color: #fff; font-weight: 600; opacity: 0.9; }
  .v4-hero__img-wrap { aspect-ratio: 4/5; background: #fff; border-radius: 32px; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; box-shadow: 0 30px 60px rgba(0,0,0,0.12); }
  .v4-hero__img-wrap img { width: 80%; height: 80%; object-fit: contain; }
  .v4-hero__sticker { position: absolute; top: -16px; right: -16px; background: var(--becky-ink); color: #fff; width: 110px; height: 110px; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; transform: rotate(12deg); font-family: 'Poppins', sans-serif; font-weight: 800; box-shadow: 0 12px 24px rgba(0,0,0,0.25); animation: v4spin 8s linear infinite; }
  .v4-hero__sticker span:first-child { font-size: 28px; line-height: 1; }
  .v4-hero__sticker span:last-child { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; margin-top: 4px; }
  @keyframes v4spin { 100% { transform: rotate(372deg); } }
  .v4-hero__credits { position: absolute; bottom: 28px; left: 28px; right: 28px; display: flex; justify-content: space-between; font-size: 12px; font-weight: 700; color: var(--becky-ink); }
  .v4-hero__credits small { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(26,26,26,0.55); display: block; margin: 0 0 2px; font-weight: 600; }

  /* MARQUEE */
  .v4-marquee { padding: 28px var(--g); background: var(--becky-ink); color: #fff; overflow: hidden; }
  .v4-marquee__track { display: flex; gap: 80px; align-items: center; animation: v4scroll 30s linear infinite; white-space: nowrap; }
  .v4-marquee__item { font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 18px; letter-spacing: -0.01em; opacity: 0.85; }
  .v4-marquee__item.dot::before { content: '·'; margin-right: 80px; color: var(--becky-peach); font-size: 32px; }
  .v4-marquee__item.label { color: var(--becky-peach); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; opacity: 1; font-weight: 800; }
  @keyframes v4scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* PRODUCT spotlight */
  .v4-product { padding: clamp(96px, 12vw, 160px) var(--g); background: #fff; }
  .v4-product__inner { max-width: 1320px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: clamp(48px, 7vw, 120px); align-items: center; }
  @media (max-width: 880px) { .v4-product__inner { grid-template-columns: 1fr; } }
  .v4-product__img { aspect-ratio: 1; background: var(--becky-blush); border-radius: 32px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
  .v4-product__img img { width: 70%; height: 70%; object-fit: contain; }
  .v4-product__corner-sticker { position: absolute; top: 24px; left: 24px; background: var(--becky-peach); color: var(--becky-ink); padding: 10px 16px; border-radius: 999px; font-weight: 800; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; transform: rotate(-6deg); }
  .v4-product__eyebrow { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--becky-pink); font-weight: 800; margin: 0 0 20px; }
  .v4-product__title { font-size: clamp(36px, 5.5vw, 64px); line-height: 1; letter-spacing: -0.025em; margin: 0 0 24px; max-width: 480px; font-weight: 800; }
  .v4-product__rating { display: flex; align-items: center; gap: 12px; margin: 0 0 32px; font-size: 14px; color: #666; }
  .v4-product__stars { color: var(--becky-pink); font-size: 18px; letter-spacing: 2px; }
  .v4-product__desc { font-size: 17px; line-height: 1.65; color: #5a5a5a; margin: 0 0 36px; max-width: 480px; }
  .v4-product__split { display: flex; gap: 0; padding: 24px 0; margin: 0 0 32px; border-top: 2px solid var(--becky-ink); border-bottom: 2px solid var(--becky-ink); }
  .v4-product__split > div { flex: 1; padding: 0 24px; border-right: 1px solid #eee; }
  .v4-product__split > div:last-child { border-right: none; }
  .v4-product__split > div:first-child { padding-left: 0; }
  .v4-product__split-label { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #999; font-weight: 700; margin: 0 0 6px; }
  .v4-product__split-value { font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 20px; letter-spacing: -0.01em; }
  .v4-product__bigcta { display: inline-flex; align-items: center; gap: 12px; padding: 20px 36px; background: var(--becky-ink); color: #fff; border-radius: 999px; font-weight: 800; font-size: 18px; transition: all 200ms ease; text-decoration: none; }
  .v4-product__bigcta:hover { background: var(--becky-pink); transform: translateY(-2px); }
  .v4-product__bigcta::after { content: '→'; font-size: 22px; transition: transform 200ms ease; }
  .v4-product__bigcta:hover::after { transform: translateX(4px); }

  /* WHY — fun 4-up with colored cards */
  .v4-why { padding: clamp(96px, 14vw, 160px) var(--g); background: var(--becky-lavender); }
  .v4-why__head { max-width: 720px; margin: 0 auto clamp(56px, 8vw, 88px); text-align: center; }
  .v4-why__eyebrow { display: inline-block; padding: 8px 16px; background: var(--becky-ink); color: #fff; border-radius: 999px; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 800; margin: 0 0 24px; }
  .v4-why__title { font-size: clamp(36px, 5.5vw, 64px); line-height: 1; letter-spacing: -0.025em; margin: 0; font-weight: 800; }
  .v4-why__grid { max-width: 1320px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  @media (max-width: 880px) { .v4-why__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .v4-why__grid { grid-template-columns: 1fr; } }
  .v4-why__card { background: #fff; padding: 36px 28px; border-radius: 24px; position: relative; transition: transform 200ms ease; }
  .v4-why__card:hover { transform: translateY(-4px); }
  .v4-why__card:nth-child(1) { background: var(--becky-peach); }
  .v4-why__card:nth-child(2) { background: var(--becky-blush); }
  .v4-why__card:nth-child(3) { background: var(--becky-peach); }
  .v4-why__card:nth-child(4) { background: #fff; }
  .v4-why__icon { font-size: 36px; margin: 0 0 16px; display: inline-block; }
  .v4-why__num { font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 14px; color: var(--becky-ink); margin: 0 0 16px; letter-spacing: 0.1em; opacity: 0.5; }
  .v4-why__card h3 { font-size: 22px; margin: 0 0 12px; line-height: 1.2; font-weight: 800; letter-spacing: -0.01em; }
  .v4-why__card p { font-size: 14px; line-height: 1.55; color: var(--becky-ink); margin: 0; opacity: 0.75; }

  /* REVIEWS */
  .v4-reviews { padding: clamp(96px, 14vw, 160px) var(--g); background: #fff; }
  .v4-reviews__head { max-width: 760px; margin: 0 auto clamp(56px, 8vw, 88px); text-align: center; }
  .v4-reviews__sticker { display: inline-block; padding: 10px 20px; background: var(--becky-pink); color: #fff; border-radius: 999px; font-weight: 800; font-size: 14px; transform: rotate(-2deg); margin: 0 0 24px; }
  .v4-reviews__head h2 { font-size: clamp(36px, 5.5vw, 64px); line-height: 1; letter-spacing: -0.025em; margin: 0 0 16px; font-weight: 800; }
  .v4-reviews__head p { color: #666; max-width: 480px; margin: 0 auto; font-size: 16px; }
  .v4-reviews__grid { max-width: 1320px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 880px) { .v4-reviews__grid { grid-template-columns: 1fr; } }
  .v4-review { padding: 36px 32px; border-radius: 24px; position: relative; transform: rotate(-1deg); }
  .v4-review:nth-child(2) { transform: rotate(1deg); }
  .v4-review:nth-child(3) { transform: rotate(-0.5deg); }
  .v4-review:nth-child(1) { background: var(--becky-blush); }
  .v4-review:nth-child(2) { background: var(--becky-peach); }
  .v4-review:nth-child(3) { background: var(--becky-peach); }
  .v4-review:hover { transform: rotate(0deg) scale(1.02); transition: transform 300ms ease; }
  .v4-review__stars { color: var(--becky-pink); font-size: 17px; letter-spacing: 2px; margin: 0 0 20px; }
  .v4-review__quote { font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 24px; line-height: 1.15; margin: 0 0 20px; letter-spacing: -0.02em; }
  .v4-review__body { font-size: 15px; line-height: 1.55; color: var(--becky-ink); margin: 0 0 24px; opacity: 0.85; }
  .v4-review__meta { display: flex; gap: 8px; align-items: center; font-size: 13px; padding-top: 20px; border-top: 1px solid rgba(26,26,26,0.1); }
  .v4-review__meta strong { color: var(--becky-ink); font-weight: 700; }
  .v4-review__verified { background: var(--becky-ink); color: #fff; padding: 3px 8px; border-radius: 4px; font-size: 10px; font-weight: 800; letter-spacing: 0.06em; }

  /* ROUTINE */
  .v4-routine { padding: clamp(96px, 14vw, 160px) var(--g); background: var(--becky-pink); color: #fff; }
  .v4-routine__inner { max-width: 1320px; margin: 0 auto; }
  .v4-routine__head { max-width: 760px; margin: 0 auto clamp(56px, 8vw, 88px); text-align: center; }
  .v4-routine__eyebrow { display: inline-block; padding: 8px 16px; background: var(--becky-peach); color: var(--becky-ink); border-radius: 999px; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 800; margin: 0 0 24px; }
  .v4-routine__head h2 { color: #fff; font-size: clamp(36px, 5.5vw, 64px); line-height: 1; letter-spacing: -0.025em; margin: 0 0 16px; font-weight: 800; }
  .v4-routine__head p { color: rgba(255,255,255,0.9); font-size: 17px; max-width: 540px; margin: 0 auto; }
  .v4-routine__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  @media (max-width: 880px) { .v4-routine__grid { grid-template-columns: 1fr; } }
  .v4-routine__step { background: #fff; color: var(--becky-ink); border-radius: 24px; padding: 40px 32px; position: relative; }
  .v4-routine__step-num { font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 80px; line-height: 0.85; color: var(--becky-pink); margin: 0 0 16px; letter-spacing: -0.04em; }
  .v4-routine__step h3 { font-size: 26px; margin: 0 0 12px; font-weight: 800; letter-spacing: -0.01em; }
  .v4-routine__step p { color: #5a5a5a; line-height: 1.55; margin: 0; font-size: 15px; }
  .v4-routine__cta { text-align: center; margin: 56px 0 0; }
  .v4-routine__cta a { display: inline-flex; align-items: center; gap: 8px; padding: 18px 36px; background: var(--becky-peach); color: var(--becky-ink); border-radius: 999px; font-weight: 800; font-size: 17px; text-decoration: none; transition: transform 200ms ease; }
  .v4-routine__cta a:hover { transform: translateY(-2px); }

  /* ATLAS */
  .v4-atlas { padding: clamp(96px, 14vw, 160px) var(--g); background: #fff; }
  .v4-atlas__inner { max-width: 1320px; margin: 0 auto; }
  .v4-atlas__head { display: flex; justify-content: space-between; align-items: end; gap: 32px; flex-wrap: wrap; margin: 0 0 clamp(56px, 8vw, 88px); }
  .v4-atlas__head h2 { font-size: clamp(36px, 5.5vw, 64px); line-height: 1; letter-spacing: -0.025em; margin: 0; font-weight: 800; }
  .v4-atlas__head p { color: #666; max-width: 480px; margin: 16px 0 0; font-size: 16px; line-height: 1.5; }
  .v4-atlas__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  @media (max-width: 880px) { .v4-atlas__grid { grid-template-columns: 1fr; } }
  .v4-atlas__card { display: block; transition: opacity 200ms ease; }
  .v4-atlas__card:hover { opacity: 0.9; }
  .v4-atlas__card-img { aspect-ratio: 5/4; background: var(--becky-blush); border-radius: 20px; overflow: hidden; margin: 0 0 20px; display: flex; align-items: center; justify-content: center; }
  .v4-atlas__card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 400ms ease; }
  .v4-atlas__card:hover .v4-atlas__card-img img { transform: scale(1.05); }
  .v4-atlas__card-meta { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--becky-pink); font-weight: 800; margin: 0 0 10px; }
  .v4-atlas__card-title { font-size: 22px; line-height: 1.2; margin: 0 0 12px; letter-spacing: -0.01em; color: var(--becky-ink); font-weight: 700; }
  .v4-atlas__card-excerpt { font-size: 14px; line-height: 1.55; color: #666; margin: 0; }

  /* TRUTH — colorful and fun */
  .v4-truth { padding: clamp(120px, 16vw, 200px) var(--g); background: linear-gradient(135deg, var(--becky-peach) 0%, var(--becky-blush) 50%, var(--becky-lavender) 100%); position: relative; overflow: hidden; text-align: center; }
  .v4-truth::before { content: ''; position: absolute; width: 320px; height: 320px; background: var(--becky-peach); border-radius: 50%; top: 20%; left: -100px; opacity: 0.5; filter: blur(60px); }
  .v4-truth::after { content: ''; position: absolute; width: 320px; height: 320px; background: var(--becky-pink); border-radius: 50%; bottom: 10%; right: -80px; opacity: 0.3; filter: blur(60px); }
  .v4-truth__inner { max-width: 760px; margin: 0 auto; position: relative; z-index: 1; }
  .v4-truth__sticker { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: var(--becky-ink); color: #fff; border-radius: 999px; font-weight: 700; font-size: 13px; letter-spacing: 0.04em; margin: 0 0 32px; transform: rotate(-2deg); }
  .v4-truth__sticker img { width: 18px; height: 18px; image-rendering: pixelated; image-rendering: crisp-edges; }
  .v4-truth h2 { font-size: clamp(40px, 6.5vw, 80px); line-height: 0.95; letter-spacing: -0.035em; margin: 0 0 36px; font-weight: 800; color: var(--becky-ink); }
  .v4-truth h2 em { font-style: normal; color: var(--becky-pink); }
  .v4-truth p { font-size: clamp(17px, 1.6vw, 20px); line-height: 1.65; color: var(--becky-ink); margin: 0 0 20px; opacity: 0.85; }

  /* CTA — final pink */
  .v4-final-cta { padding: clamp(80px, 12vw, 140px) var(--g); background: var(--becky-ink); color: #fff; text-align: center; }
  .v4-final-cta__inner { max-width: 720px; margin: 0 auto; }
  .v4-final-cta__eyebrow { display: inline-block; padding: 10px 20px; background: var(--becky-pink); color: #fff; border-radius: 999px; font-weight: 700; font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; margin: 0 0 28px; }
  .v4-final-cta h2 { color: #fff; font-size: clamp(36px, 5.5vw, 64px); line-height: 1; letter-spacing: -0.025em; margin: 0 0 24px; font-weight: 800; }
  .v4-final-cta p { color: rgba(255,255,255,0.8); margin: 0 0 40px; font-size: 17px; max-width: 480px; margin-left: auto; margin-right: auto; }
  .v4-final-cta a.btn { display: inline-flex; align-items: center; gap: 12px; padding: 20px 40px; background: var(--becky-pink); color: #fff; border-radius: 999px; font-weight: 800; font-size: 18px; text-decoration: none; transition: all 200ms ease; }
  .v4-final-cta a.btn:hover { background: var(--becky-peach); color: var(--becky-ink); transform: translateY(-2px); }
</style>

<div class="v4">

  <!-- HERO — yellow + pink, fun -->
  <section class="v4-hero">
    <div class="v4-hero__inner">
      <div>
        <span class="v4-hero__pill">{% render 'becky-pixel-peach', size: 22 %} Hi, we're Becky</span>
        <h1 class="v4-hero__title">The skin no one talks about <em>deserves a routine.</em></h1>
        <p class="v4-hero__sub">A walnut-shell + rosehip exfoliant for buttne, KP, ingrowns, and dark spots. Vegan, cruelty-free, $20.</p>
        <div class="v4-hero__ctas">
          <a href="/products/booty-scrub" class="v4-hero__btn-primary">Shop the Scrub →</a>
          <a href="/pages/routine" class="v4-hero__small-text" style="text-decoration: underline; text-underline-offset: 4px;">or read the routine first</a>
        </div>
      </div>
      <div class="v4-hero__img-wrap">
        <span class="v4-hero__sticker"><span>$20</span><span>Always</span></span>
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" width="800" height="800">
        {%- endif -%}
        <div class="v4-hero__credits">
          <div><small>Bestseller</small><strong>Booty Scrub · 2oz</strong></div>
          <div style="text-align:right;"><small>Rating</small><strong>★ {{ avg_rating }} ({{ review_count }})</strong></div>
        </div>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="v4-marquee">
    <div class="v4-marquee__track">
      <span class="v4-marquee__item label">★ As featured in</span>
      <span class="v4-marquee__item">Cosmopolitan</span>
      <span class="v4-marquee__item">PopSugar</span>
      <span class="v4-marquee__item">Marie Claire</span>
      <span class="v4-marquee__item">Yahoo</span>
      <span class="v4-marquee__item">Bustle</span>
      <span class="v4-marquee__item">Refinery29</span>
      <span class="v4-marquee__item label">★ As featured in</span>
      <span class="v4-marquee__item">Cosmopolitan</span>
      <span class="v4-marquee__item">PopSugar</span>
      <span class="v4-marquee__item">Marie Claire</span>
      <span class="v4-marquee__item">Yahoo</span>
      <span class="v4-marquee__item">Bustle</span>
      <span class="v4-marquee__item">Refinery29</span>
    </div>
  </div>

  {%- if product != blank -%}
  <section class="v4-product">
    <div class="v4-product__inner">
      <div class="v4-product__img">
        <span class="v4-product__corner-sticker">★ Bestseller</span>
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" width="800" height="800">
        {%- endif -%}
      </div>
      <div>
        <p class="v4-product__eyebrow">The Original · N° 01</p>
        <h2 class="v4-product__title">{{ product.title }}</h2>
        <div class="v4-product__rating">
          <span class="v4-product__stars">★★★★★</span>
          <span><strong>{{ avg_rating }}</strong> from {{ review_count }}+ verified reviews</span>
        </div>
        <p class="v4-product__desc">Walnut shell + rosehip exfoliant for the skin between your hip and your knee. Smooths buttne, KP, ingrowns, and dark spots in 4 weeks.</p>
        <div class="v4-product__split">
