{%- comment -%}
  Becky article — v4 with reliable Read Next + colorful design
{%- endcomment -%}

{%- assign atlas_blog = blogs.booty-atlas -%}
{%- assign related_handles = article.metafields.becky.related_articles.value -%}

<style>
  .art-v4 { font-family: 'Work Sans', system-ui, sans-serif; color: var(--becky-ink); }
  .art-v4 h1, .art-v4 h2, .art-v4 h3 { font-family: 'Poppins', sans-serif; line-height: 1.15; }

  .art-v4__hero { padding: 80px var(--g, 24px) 64px; background: linear-gradient(135deg, var(--becky-blush) 0%, var(--becky-peach) 100%); }
  .art-v4__hero-inner { max-width: 800px; margin: 0 auto; }
  .art-v4__crumb { font-size: 13px; margin: 0 0 24px; opacity: 0.7; }
  .art-v4__crumb a { color: var(--becky-pink); font-weight: 600; }
  .art-v4__title { font-size: clamp(36px, 5.5vw, 60px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 24px; font-weight: 800; text-wrap: balance; }
  .art-v4__meta { display: flex; flex-wrap: wrap; gap: 16px; font-size: 14px; color: var(--becky-grey); margin: 0; align-items: center; }
  .art-v4__meta-pill { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.7); padding: 6px 14px; border-radius: 999px; font-weight: 600; font-size: 13px; }

  .art-v4__body-wrap { max-width: 720px; margin: 0 auto; padding: 64px 24px; }
  .art-v4__tldr { background: var(--becky-peach); border-radius: 24px; padding: 28px 32px; margin: 0 0 48px; }
  .art-v4__tldr-label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--becky-ink); font-weight: 800; margin: 0 0 12px; }
  .art-v4__tldr-text { font-size: 18px; line-height: 1.55; margin: 0; font-weight: 500; }

  .art-v4__body { font-size: 18px; line-height: 1.75; color: #2a2a2a; }
  .art-v4__body h2 { font-size: clamp(26px, 3.8vw, 34px); margin: 56px 0 20px; letter-spacing: -0.015em; }
  .art-v4__body h3 { font-size: clamp(20px, 2.8vw, 24px); margin: 36px 0 14px; }
  .art-v4__body p { margin: 0 0 20px; }
  .art-v4__body a { color: var(--becky-pink); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1.5px; font-weight: 600; }
  .art-v4__body a:hover { color: var(--becky-pink-dark); }
  .art-v4__body ul, .art-v4__body ol { padding-left: 24px; margin: 0 0 24px; }
  .art-v4__body li { margin: 0 0 12px; }
  .art-v4__body strong { font-weight: 700; }
  .art-v4__body blockquote { border-left: 4px solid var(--becky-pink); padding: 16px 28px; margin: 32px 0; background: var(--becky-blush); border-radius: 0 16px 16px 0; font-size: 18px; }
  .art-v4__body blockquote p:last-child { margin: 0; }

  .art-v4__share { margin: 48px 0 0; padding: 28px 0 32px; border-top: 1px solid var(--becky-border); border-bottom: 1px solid var(--becky-border); }
  .art-v4__share-label { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--becky-pink); font-weight: 800; margin: 0 0 16px; }
  .art-v4__share-row { display: flex; gap: 8px; flex-wrap: wrap; }
  .art-v4__share-btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; background: var(--becky-light); border: 1px solid var(--becky-border); border-radius: 999px; font-size: 13px; font-weight: 600; color: var(--becky-ink); text-decoration: none; cursor: pointer; font-family: inherit; transition: all 200ms ease; }
  .art-v4__share-btn:hover { background: var(--becky-pink); color: #fff; border-color: var(--becky-pink); transform: translateY(-1px); }
  .art-v4__share-btn.is-copied { background: var(--becky-peach); color: var(--becky-ink); border-color: var(--becky-peach); }
  .art-v4__cta { background: var(--becky-pink); color: #fff; border-radius: 24px; padding: 48px 36px; margin: 56px 0; text-align: center; }
  .art-v4__cta h3 { color: #fff; margin: 0 0 16px; font-size: 28px; font-weight: 800; letter-spacing: -0.02em; }
  .art-v4__cta p { color: rgba(255,255,255,0.95); margin: 0 0 24px; font-size: 16px; }
  .art-v4__cta a { display: inline-flex; align-items: center; gap: 8px; background: #fff; color: var(--becky-pink); padding: 16px 32px; border-radius: 999px; font-weight: 800; text-decoration: none; transition: transform 200ms ease; }
  .art-v4__cta a:hover { transform: translateY(-2px); }

  /* READ NEXT — fixed and clean */
  .art-v4__related { background: var(--becky-lavender); padding: 80px var(--g, 24px); margin: 80px 0 0; }
  .art-v4__related-inner { max-width: 1280px; margin: 0 auto; }
  .art-v4__related-head { text-align: center; margin: 0 0 48px; }
  .art-v4__related-eyebrow { display: inline-block; padding: 8px 16px; background: var(--becky-ink); color: #fff; border-radius: 999px; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 800; margin: 0 0 16px; }
  .art-v4__related-title { font-size: clamp(28px, 4.5vw, 44px); line-height: 1; letter-spacing: -0.025em; margin: 0; font-weight: 800; }
  .art-v4__related-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  @media (max-width: 880px) { .art-v4__related-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .art-v4__related-grid { grid-template-columns: 1fr; } }
  .art-v4__related-card { background: #fff; border-radius: 20px; overflow: hidden; transition: transform 200ms ease, box-shadow 200ms ease; display: block; color: var(--becky-ink); }
  .art-v4__related-card:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.08); }
  .art-v4__related-img { aspect-ratio: 4/3; background: var(--becky-blush); overflow: hidden; display: flex; align-items: center; justify-content: center; font-size: 32px; }
  .art-v4__related-img img { width: 100%; height: 100%; object-fit: cover; }
  .art-v4__related-card-body { padding: 20px; }
  .art-v4__related-card-meta { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--becky-pink); font-weight: 800; margin: 0 0 8px; }
  .art-v4__related-card h4 { font-size: 16px; line-height: 1.3; margin: 0 0 10px; letter-spacing: -0.01em; font-weight: 700; }
  .art-v4__related-card p { font-size: 13px; line-height: 1.5; color: #666; margin: 0; }
</style>

<article class="art-v4">

  <header class="art-v4__hero">
    <div class="art-v4__hero-inner">
      <p class="art-v4__crumb"><a href="/">Becky</a> · <a href="/blogs/booty-atlas">The Booty Atlas</a></p>
      <h1 class="art-v4__title">{{ article.title }}</h1>
      <div class="art-v4__meta">
        <span class="art-v4__meta-pill">📅 {{ article.published_at | date: '%B %-d, %Y' }}</span>
        {%- if article.metafields.becky.reading_time_min -%}<span class="art-v4__meta-pill">⏱ {{ article.metafields.becky.reading_time_min }} min</span>{%- endif -%}
        {%- if article.author and article.author != blank -%}<span class="art-v4__meta-pill">By {{ article.author }}</span>{%- endif -%}
      </div>
    </div>
  </header>

  <div class="art-v4__body-wrap">
    {%- if article.metafields.becky.tldr != blank -%}
      <div class="art-v4__tldr">
        <p class="art-v4__tldr-label">★ TL;DR</p>
        <p class="art-v4__tldr-text">{{ article.metafields.becky.tldr }}</p>
      </div>
    {%- endif -%}

    <div class="art-v4__body">{{ article.content }}</div>

    <!-- SHARE BUTTONS -->
    {%- assign share_url = canonical_url | default: shop.url | append: article.url -%}
    {%- assign share_text = article.title | url_encode -%}
    <div class="art-v4__share">
      <p class="art-v4__share-label">Share this</p>
      <div class="art-v4__share-row">
        <a href="https://twitter.com/intent/tweet?text={{ share_text }}&url={{ share_url | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Twitter" class="art-v4__share-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05A4.28 4.28 0 0 0 15.5 4a4.29 4.29 0 0 0-4.21 5.27A12.16 12.16 0 0 1 3 4.79a4.28 4.28 0 0 0 1.33 5.72c-.7-.02-1.37-.21-1.95-.53v.05a4.29 4.29 0 0 0 3.44 4.2c-.67.18-1.37.21-2.05.08a4.29 4.29 0 0 0 4 2.98 8.62 8.62 0 0 1-5.34 1.84A8.7 8.7 0 0 1 1.5 19.05a12.13 12.13 0 0 0 6.55 1.92c7.85 0 12.15-6.51 12.15-12.16v-.55c.83-.6 1.55-1.36 2.12-2.22-.77.34-1.59.57-2.46.67z"/></svg>
          <span>Twitter</span>
        </a>
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ share_url | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Facebook" class="art-v4__share-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
          <span>Facebook</span>
        </a>
        <a href="https://pinterest.com/pin/create/button/?url={{ share_url | url_encode }}&description={{ share_text }}{% if article.image %}&media={{ article.image | image_url: width: 1200 | url_encode }}{% endif %}" target="_blank" rel="noopener" aria-label="Share on Pinterest" class="art-v4__share-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0a12 12 0 0 0-4.37 23.17c-.1-.94-.2-2.4.04-3.43.22-.93 1.4-5.94 1.4-5.94s-.36-.72-.36-1.78c0-1.67.97-2.92 2.17-2.92 1.02 0 1.52.77 1.52 1.69 0 1.03-.66 2.57-1 4-.28 1.2.6 2.18 1.78 2.18 2.14 0 3.78-2.26 3.78-5.51 0-2.88-2.07-4.9-5.03-4.9-3.42 0-5.43 2.57-5.43 5.22 0 1.04.4 2.15.9 2.75.1.12.1.22.08.34l-.34 1.36c-.06.22-.18.27-.4.16-1.5-.7-2.43-2.88-2.43-4.64 0-3.78 2.75-7.26 7.92-7.26 4.16 0 7.4 2.96 7.4 6.93 0 4.13-2.61 7.46-6.23 7.46-1.22 0-2.36-.63-2.75-1.38l-.75 2.85c-.27 1.04-1 2.34-1.5 3.14A12 12 0 1 0 12 0z"/></svg>
          <span>Pinterest</span>
        </a>
        <a href="mailto:?subject={{ article.title | url_encode }}&body=I thought you'd like this: {{ share_url }}" aria-label="Share by email" class="art-v4__share-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span>Email</span>
        </a>
        <button type="button" class="art-v4__share-btn" data-action="copy" data-url="{{ share_url }}" aria-label="Copy link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          <span>Copy link</span>
        </button>
      </div>
    </div>

    <div class="art-v4__cta">
      <h3>Smooth, even, confident skin in 4 weeks.</h3>
      <p>The Becky Booty Scrub — walnut shell + rosehip exfoliant, $20, ships free over $35.</p>
      <a href="/products/booty-scrub">Shop the Scrub →</a>
    </div>
  </div>

  <script>
    (function(){
      var copyBtns = document.querySelectorAll('[data-action="copy"]');
      copyBtns.forEach(function(btn){
        btn.addEventListener('click', function(){
          var url = btn.dataset.url;
          if (navigator.clipboard) {
            navigator.clipboard.writeText(url).then(function(){
              var orig = btn.innerHTML;
              btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Copied!</span>';
              btn.classList.add('is-copied');
              setTimeout(function(){ btn.innerHTML = orig; btn.classList.remove('is-copied'); }, 2000);
            });
          }
        });
      });
    })();
  </script>

  {%- if related_handles != blank and related_handles.size > 0 -%}
    <div class="art-v4__related">
      <div class="art-v4__related-inner">
        <div class="art-v4__related-head">
          <p class="art-v4__related-eyebrow">★ Keep reading</p>
          <h2 class="art-v4__related-title">Read next from The Atlas</h2>
        </div>
        <div class="art-v4__related-grid">
          {%- for handle in related_handles limit: 4 -%}
            {%- assign related = articles[handle] -%}
            {%- if related == blank -%}
              {%- assign related_path = 'booty-atlas/' | append: handle -%}
              {%- assign related = articles[related_path] -%}
            {%- endif -%}
            {%- if related != blank -%}
              <a href="{{ related.url }}" class="art-v4__related-card">
                <div class="art-v4__related-img">
                  {%- if related.image -%}<img src="{{ related.image | image_url: width: 600 }}" alt="{{ related.title | escape }}" loading="lazy">{%- else -%}🍑{%- endif -%}
                </div>
                <div class="art-v4__related-card-body">
                  <p class="art-v4__related-card-meta">{%- if related.metafields.becky.reading_time_min -%}{{ related.metafields.becky.reading_time_min }} min read{%- else -%}The Atlas{%- endif -%}</p>
                  <h4>{{ related.title }}</h4>
                  <p>{{ related.metafields.becky.tldr | default: related.excerpt | strip_html | truncate: 100 }}</p>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

</article>
