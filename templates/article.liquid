{%- comment -%}
  Becky article template — OS 1.0 liquid
  Renders Booty Atlas articles with TL;DR, reading time, related articles
{%- endcomment -%}

<style>
  .becky-article { font-family: 'Work Sans', system-ui, sans-serif; color: #1a1a1a; max-width: 760px; margin: 0 auto; padding: 32px 24px; }
  .becky-article h1, .becky-article h2, .becky-article h3 { font-family: 'Poppins', 'Work Sans', system-ui, sans-serif; line-height: 1.2; }
  .becky-article__breadcrumb { font-size: 14px; color: #666; margin: 0 0 16px; }
  .becky-article__breadcrumb a { color: #ff3465; text-decoration: none; }
  .becky-article__title { font-size: clamp(32px, 5vw, 48px); line-height: 1.1; margin: 0 0 16px; text-wrap: balance; font-weight: 700; }
  .becky-article__meta { display: flex; flex-wrap: wrap; gap: 12px; font-size: 14px; color: #666; margin: 0 0 32px; }
  .becky-article__meta span { display: inline-flex; align-items: center; gap: 4px; }
  .becky-article__tldr { background: #ffebeb; border-left: 4px solid #ff3465; padding: 20px 24px; border-radius: 8px; margin: 0 0 40px; }
  .becky-article__tldr-label { font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: #ff3465; font-weight: 700; margin: 0 0 8px; }
  .becky-article__tldr-text { font-size: 17px; line-height: 1.6; margin: 0; }
  .becky-article__body { font-size: 18px; line-height: 1.7; color: #2a2a2a; }
  .becky-article__body h2 { font-size: clamp(24px, 3.5vw, 32px); margin: 48px 0 16px; }
  .becky-article__body h3 { font-size: clamp(20px, 3vw, 24px); margin: 32px 0 12px; }
  .becky-article__body p { margin: 0 0 20px; }
  .becky-article__body a { color: #ff3465; text-decoration: underline; }
  .becky-article__body ul, .becky-article__body ol { padding-left: 24px; margin: 0 0 20px; }
  .becky-article__body li { margin: 0 0 8px; }
  .becky-article__body blockquote { border-left: 4px solid #ff3465; padding: 12px 24px; margin: 24px 0; font-style: italic; color: #555; }

  .becky-related { background: #f3e5fe; padding: 48px 24px; margin: 64px -24px -32px; border-radius: 24px 24px 0 0; }
  .becky-related__title { font-size: 24px; margin: 0 0 24px; text-align: center; }
  .becky-related__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; max-width: 1000px; margin: 0 auto; }
  .becky-related__card { background: #fff; border-radius: 12px; padding: 20px; text-decoration: none; color: #1a1a1a; transition: transform 200ms ease; display: block; }
  .becky-related__card:hover { transform: translateY(-2px); }
  .becky-related__card h3 { font-size: 16px; margin: 0 0 8px; line-height: 1.3; }
  .becky-related__card p { font-size: 13px; color: #666; margin: 0; line-height: 1.4; }

  .becky-article__cta { background: #ff3465; color: #fff; padding: 32px; border-radius: 16px; margin: 48px 0 32px; text-align: center; }
  .becky-article__cta h3 { color: #fff; margin: 0 0 12px; font-size: 22px; }
  .becky-article__cta p { margin: 0 0 16px; }
  .becky-article__cta a { display: inline-block; background: #fff; color: #ff3465; padding: 12px 24px; border-radius: 999px; font-weight: 700; text-decoration: none; }
</style>

<article class="becky-article">
  <p class="becky-article__breadcrumb">
    <a href="/">Becky</a> · <a href="/blogs/booty-atlas">The Booty Atlas</a>
  </p>

  <h1 class="becky-article__title">{{ article.title }}</h1>

  <div class="becky-article__meta">
    <span>📅 {{ article.published_at | date: '%B %-d, %Y' }}</span>
    {%- if article.metafields.becky.reading_time_min -%}
      <span>·</span><span>⏱ {{ article.metafields.becky.reading_time_min }} min read</span>
    {%- endif -%}
    {%- if article.author and article.author != blank -%}
      <span>·</span><span>By {{ article.author }}</span>
    {%- endif -%}
  </div>

  {%- if article.metafields.becky.tldr != blank -%}
    <div class="becky-article__tldr">
      <p class="becky-article__tldr-label">TL;DR</p>
      <p class="becky-article__tldr-text">{{ article.metafields.becky.tldr }}</p>
    </div>
  {%- endif -%}

  <div class="becky-article__body">
    {{ article.content }}
  </div>

  <!-- Inline CTA -->
  <div class="becky-article__cta">
    <h3>Smooth, even, confident skin in 4 weeks</h3>
    <p>The Becky Booty Scrub — walnut shell + rosehip exfoliant, $20, ships free.</p>
    <a href="/products/booty-scrub">Shop the Scrub →</a>
  </div>

  {%- assign related_handles = article.metafields.becky.related_articles.value -%}
  {%- if related_handles and related_handles.size > 0 -%}
    <div class="becky-related">
      <h2 class="becky-related__title">Read next</h2>
      <div class="becky-related__grid">
        {%- assign atlas_blog = blogs['booty-atlas'] -%}
        {%- for handle in related_handles limit: 4 -%}
          {%- assign related = atlas_blog.articles | where: 'handle', handle | first -%}
          {%- if related -%}
            <a href="{{ related.url }}" class="becky-related__card">
              <h3>{{ related.title }}</h3>
              <p>{{ related.metafields.becky.tldr | default: related.excerpt | strip_html | truncate: 120 }}</p>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</article>
