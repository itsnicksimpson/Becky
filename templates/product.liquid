{%- comment -%}
  Becky PDP — polished v2
  Gallery + sticky ATC + expandable desc + trust signals + ingredients + steps + timeline + FAQ
{%- endcomment -%}

{%- assign rating = product.metafields.becky.rating_value | default: 4.7 -%}
{%- assign review_count = product.metafields.becky.review_count | default: 1247 -%}

<style>
  .b-pdp { max-width: 1280px; margin: 0 auto; padding: 32px 24px; }
  .b-pdp__crumb { font-size: 13px; color: var(--becky-grey); margin: 0 0 24px; }
  .b-pdp__crumb a { color: var(--becky-pink); }
  .b-pdp__hero { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; margin: 0 0 96px; }
  @media (max-width: 880px) { .b-pdp__hero { grid-template-columns: 1fr; gap: 32px; } }

  /* GALLERY */
  .b-pdp__gallery { position: sticky; top: 96px; }
  .b-pdp__main-img { background: var(--becky-blush); border-radius: 24px; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; margin: 0 0 16px; }
  .b-pdp__main-img img { width: 90%; height: 90%; object-fit: contain; }
  .b-pdp__badge { position: absolute; top: 20px; left: 20px; background: var(--becky-yellow); padding: 8px 14px; border-radius: 999px; font-weight: 700; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; }
  .b-pdp__thumbs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .b-pdp__thumbs { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; }
  .b-pdp__thumb { background: var(--becky-light); border-radius: 12px; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 160ms ease; border: 2px solid transparent; position: relative; overflow: hidden; }
  .b-pdp__thumb:hover, .b-pdp__thumb.is-active { border-color: var(--becky-pink); }
  .b-pdp__thumb img { width: 88%; height: 88%; object-fit: contain; }
  .b-pdp__thumb--video { background: linear-gradient(135deg, #1a1a1a 0%, #4a4a4a 100%); }
  .b-pdp__thumb--video[data-empty="true"] { opacity: 0.4; cursor: not-allowed; }
  .b-pdp__thumb-vid { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }

  /* INFO PANEL */
  .b-pdp__eyebrow { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--becky-pink); font-weight: 700; margin: 0 0 12px; }
  .b-pdp__title { font-size: clamp(28px, 4vw, 42px); margin: 0 0 16px; }
  .b-pdp__rating { display: flex; align-items: center; gap: 8px; margin: 0 0 24px; flex-wrap: wrap; }
  .b-pdp__rating .stars { color: var(--becky-pink); font-size: 18px; letter-spacing: 2px; }
  .b-pdp__rating .num { font-weight: 700; }
  .b-pdp__rating a { color: var(--becky-grey); text-decoration: underline; font-size: 14px; }
  .b-pdp__price-row { display: flex; align-items: baseline; gap: 12px; margin: 0 0 8px; }
  .b-pdp__price { font-family: 'Poppins', sans-serif; font-size: 32px; font-weight: 700; }
  .b-pdp__compare { font-size: 18px; color: #888; text-decoration: line-through; }
  .b-pdp__sub { font-size: 13px; color: var(--becky-grey); margin: 0 0 28px; }

  .b-pdp__chip-row { display: flex; flex-wrap: wrap; gap: 8px; margin: 0 0 28px; }
  .b-pdp__chip { padding: 6px 12px; border-radius: 999px; background: var(--becky-light); font-size: 13px; font-weight: 600; }

  /* PURCHASE OPTIONS */
  .b-pdp__buy-options { margin: 0 0 24px; }
  .b-pdp__buy-option { border: 2px solid var(--becky-border); border-radius: 16px; padding: 16px 20px; margin: 0 0 10px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; transition: all 160ms ease; }
  .b-pdp__buy-option:has(input:checked) { border-color: var(--becky-pink); background: var(--becky-blush); }
  .b-pdp__buy-option input { margin-right: 12px; accent-color: var(--becky-pink); }
  .b-pdp__buy-option-label { font-weight: 600; }
  .b-pdp__buy-option-meta { font-size: 13px; color: var(--becky-grey); display: block; margin-top: 2px; font-weight: 400; }
  .b-pdp__buy-option-save { background: var(--becky-pink); color: #fff; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 700; }

  .b-pdp__cta-row { display: flex; gap: 12px; }
  .b-pdp__cta { flex: 1; padding: 18px 32px; background: var(--becky-pink); color: #fff; border: none; border-radius: 999px; font-weight: 700; font-size: 17px; cursor: pointer; transition: all 200ms ease; font-family: inherit; }
  .b-pdp__cta:hover { background: var(--becky-pink-dark); transform: translateY(-1px); box-shadow: 0 12px 24px rgba(255,52,101,0.25); }

  .b-pdp__trust { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin: 24px 0 0; padding: 20px 0; border-top: 1px solid var(--becky-border); border-bottom: 1px solid var(--becky-border); font-size: 12px; color: var(--becky-grey); }
  .b-pdp__trust > div { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .b-pdp__trust svg { width: 20px; height: 20px; color: var(--becky-pink); }

  /* DESCRIPTION (expandable) */
  .b-pdp__desc { margin: 24px 0 0; }
  .b-pdp__desc-content { font-size: 16px; line-height: 1.7; color: var(--becky-grey); position: relative; max-height: 220px; overflow: hidden; transition: max-height 300ms ease; }
  .b-pdp__desc-content::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 80px; background: linear-gradient(transparent, #fff); pointer-events: none; }
  .b-pdp__desc-content.is-expanded { max-height: 2000px; }
  .b-pdp__desc-content.is-expanded::after { display: none; }
  .b-pdp__desc-toggle { background: none; border: none; color: var(--becky-pink); font-weight: 700; padding: 12px 0 0; cursor: pointer; font-family: inherit; font-size: 14px; display: inline-flex; align-items: center; gap: 6px; }

  /* SECTIONS */
  .b-section { padding: 64px 0; border-top: 1px solid var(--becky-border); }
  .b-section__title { text-align: center; font-size: clamp(24px, 3.5vw, 36px); margin: 0 0 48px; }

  .b-ingredients { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }
  .b-ingredient { background: var(--becky-yellow); border-radius: 20px; padding: 24px; transition: transform 200ms ease; }
  .b-ingredient:hover { transform: translateY(-2px); }
  .b-ingredient h3 { font-size: 17px; margin: 0 0 8px; }
  .b-ingredient p { font-size: 14px; margin: 0; line-height: 1.5; color: var(--becky-ink); }

  .b-best-for { background: var(--becky-lavender); border-radius: 24px; padding: 48px 32px; }
  .b-best-for__list { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; max-width: 900px; margin: 0 auto; }
  .b-best-for__item { background: #fff; padding: 12px 20px; border-radius: 999px; font-weight: 600; font-size: 15px; }

  .b-steps { counter-reset: stp; max-width: 800px; margin: 0 auto; }
  .b-step { display: grid; grid-template-columns: 70px 1fr; gap: 24px; padding: 24px 0; border-bottom: 1px solid var(--becky-border); align-items: start; counter-increment: stp; }
  .b-step__num { width: 60px; height: 60px; border-radius: 50%; background: var(--becky-pink); color: #fff; display: flex; align-items: center; justify-content: center; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 26px; }
  .b-step__num::before { content: counter(stp); }
  .b-step h3 { font-size: 19px; margin: 0 0 6px; }
  .b-step p { color: var(--becky-grey); line-height: 1.55; margin: 0; }

  .b-timeline { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; }
  .b-mile { background: var(--becky-blush); border-radius: 20px; padding: 24px; text-align: center; }
  .b-mile__week { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--becky-pink); font-weight: 700; margin: 0 0 8px; }
  .b-mile__title { font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 16px; margin: 0; line-height: 1.4; }

  .b-faq { max-width: 760px; margin: 0 auto; }
  .b-faq details { border-bottom: 1px solid var(--becky-border); padding: 24px 0; }
  .b-faq summary { cursor: pointer; list-style: none; display: flex; justify-content: space-between; gap: 16px; font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 18px; line-height: 1.4; color: var(--becky-ink); }
  .b-faq summary::-webkit-details-marker { display: none; }
  .b-faq summary::after { content: '+'; font-size: 26px; font-weight: 400; line-height: 1; transition: transform 200ms ease; color: var(--becky-pink); flex-shrink: 0; }
  .b-faq details[open] summary::after { transform: rotate(45deg); }
  .b-faq__answer { padding-top: 16px; line-height: 1.65; color: var(--becky-grey); font-size: 15px; }

  /* STICKY ATC BAR — desktop + mobile, appears on scroll */
  .b-sticky-atc { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; border-top: 2px solid var(--becky-ink); padding: 14px 24px; z-index: 80; display: flex; align-items: center; gap: 20px; max-width: 1280px; margin: 0 auto; box-shadow: 0 -12px 30px rgba(0,0,0,0.08); transform: translateY(100%); transition: transform 320ms cubic-bezier(0.4, 0, 0.2, 1); }
  .b-sticky-atc.is-visible { transform: translateY(0); }
  .b-sticky-atc__img { width: 56px; height: 56px; border-radius: 12px; background: var(--becky-blush); display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; }
  .b-sticky-atc__img img { width: 80%; height: 80%; object-fit: contain; }
  .b-sticky-atc__info { flex: 1; min-width: 0; }
  .b-sticky-atc__title { font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 15px; margin: 0 0 2px; letter-spacing: -0.01em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .b-sticky-atc__meta { font-size: 12px; color: var(--becky-grey); display: flex; gap: 10px; align-items: center; }
  .b-sticky-atc__meta strong { color: var(--becky-pink); font-weight: 700; }
  .b-sticky-atc__btn { padding: 14px 28px; background: var(--becky-pink); color: #fff; border: none; border-radius: 999px; font-weight: 800; font-size: 15px; cursor: pointer; font-family: inherit; transition: all 200ms ease; display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; }
  .b-sticky-atc__btn:hover { background: var(--becky-pink-dark); transform: translateY(-1px); }
  .b-sticky-atc__btn::after { content: '→'; transition: transform 200ms ease; }
  .b-sticky-atc__btn:hover::after { transform: translateX(3px); }
  @media (max-width: 540px) { .b-sticky-atc__title { font-size: 14px; } .b-sticky-atc__btn { padding: 12px 18px; font-size: 13px; } .b-sticky-atc { padding: 10px 14px; gap: 12px; } .b-sticky-atc__img { width: 48px; height: 48px; } }
</style>

<div class="b-pdp">
  <p class="b-pdp__crumb"><a href="/">Becky</a> · <a href="/products/booty-scrub">Shop</a> · {{ product.title }}</p>

  <div class="b-pdp__hero">

    <!-- GALLERY (with 2 video slots) -->
    <div class="b-pdp__gallery">
      <div class="b-pdp__main-img" id="bMainImg">
        <span class="b-pdp__badge">★ {{ rating }} · {{ review_count }}+ reviews</span>
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" id="bMainImgEl" width="800" height="800">
        {%- else -%}
          <div style="font-size: 200px;">🍑</div>
        {%- endif -%}
        {%- assign vid1 = product.metafields.becky.video_1 | default: '' -%}
        {%- assign vid2 = product.metafields.becky.video_2 | default: '' -%}
        {%- if vid1 != '' -%}
          <video id="bMainVid1" src="{{ vid1 }}" controls playsinline preload="metadata" style="display:none;position:absolute;inset:8%;width:84%;height:84%;object-fit:contain;border-radius:16px;background:#000;"></video>
        {%- endif -%}
        {%- if vid2 != '' -%}
          <video id="bMainVid2" src="{{ vid2 }}" controls playsinline preload="metadata" style="display:none;position:absolute;inset:8%;width:84%;height:84%;object-fit:contain;border-radius:16px;background:#000;"></video>
        {%- endif -%}
      </div>
      <div class="b-pdp__thumbs">
        {%- for image in product.images limit: 4 -%}
          <div class="b-pdp__thumb{% if forloop.first %} is-active{% endif %}" data-type="image" data-src="{{ image | image_url: width: 1200 }}">
            <img src="{{ image | image_url: width: 240 }}" alt="" loading="lazy">
          </div>
        {%- endfor -%}
        <!-- Video slot 1 -->
        <div class="b-pdp__thumb b-pdp__thumb--video" data-type="video" data-vid="1" {% if vid1 == '' %}data-empty="true"{% endif %}>
          <div class="b-pdp__thumb-vid">
            <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;color:#fff;"><path d="M8 5v14l11-7z"/></svg>
            <span style="position:absolute;bottom:6px;left:0;right:0;font-size:9px;letter-spacing:0.08em;text-transform:uppercase;color:#fff;font-weight:700;text-align:center;">Video</span>
          </div>
        </div>
        <!-- Video slot 2 -->
        <div class="b-pdp__thumb b-pdp__thumb--video" data-type="video" data-vid="2" {% if vid2 == '' %}data-empty="true"{% endif %}>
          <div class="b-pdp__thumb-vid">
            <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;color:#fff;"><path d="M8 5v14l11-7z"/></svg>
            <span style="position:absolute;bottom:6px;left:0;right:0;font-size:9px;letter-spacing:0.08em;text-transform:uppercase;color:#fff;font-weight:700;text-align:center;">Video</span>
          </div>
        </div>
      </div>
      <script>
        (function(){
          var thumbs = document.querySelectorAll('.b-pdp__thumb');
          var mainImg = document.getElementById('bMainImgEl');
          var vid1 = document.getElementById('bMainVid1');
          var vid2 = document.getElementById('bMainVid2');
          thumbs.forEach(function(t){
            t.addEventListener('click', function(){
              if (t.dataset.empty === 'true') return; // skip if no video set
              thumbs.forEach(function(x){ x.classList.remove('is-active'); });
              t.classList.add('is-active');
              if (t.dataset.type === 'image') {
                if (mainImg) { mainImg.style.display='block'; mainImg.src = t.dataset.src; }
                if (vid1) { vid1.pause(); vid1.style.display='none'; }
                if (vid2) { vid2.pause(); vid2.style.display='none'; }
              } else if (t.dataset.type === 'video') {
                if (mainImg) mainImg.style.display='none';
                var targetVid = t.dataset.vid === '1' ? vid1 : vid2;
                var otherVid = t.dataset.vid === '1' ? vid2 : vid1;
                if (otherVid) { otherVid.pause(); otherVid.style.display='none'; }
                if (targetVid) { targetVid.style.display='block'; targetVid.play().catch(function(){}); }
              }
            });
          });
        })();
      </script>
    </div>

    <!-- INFO -->
    <div>
      <p class="b-pdp__eyebrow">The original</p>
      <h1 class="b-pdp__title">{{ product.title }}</h1>

      <div class="b-pdp__rating">
        <junip-product-summary product-id="{{ product.id }}"></junip-product-summary>
      </div>

      <div class="b-pdp__price-row">
        <span class="b-pdp__price">{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}
          <span class="b-pdp__compare">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </div>
      <p class="b-pdp__sub">Free US shipping over $35 · 30-day money-back · Ships in 1-2 days</p>

      <div class="b-pdp__chip-row">
        <span class="b-pdp__chip">For: buttne</span>
        <span class="b-pdp__chip">KP</span>
        <span class="b-pdp__chip">Ingrowns</span>
        <span class="b-pdp__chip">Dark spots</span>
      </div>

      <form action="/cart/add" method="post" enctype="multipart/form-data">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <div class="b-pdp__buy-options">
          <label class="b-pdp__buy-option">
            <span style="display: flex; align-items: center;">
              <input type="radio" name="selling_plan" value="" checked>
              <span class="b-pdp__buy-option-label">One-time purchase<span class="b-pdp__buy-option-meta">Ships in 1-2 days · Free over $35</span></span>
            </span>
            <span style="font-weight: 700;">{{ product.price | money }}</span>
          </label>
          <label class="b-pdp__buy-option">
            <span style="display: flex; align-items: center;">
              <input type="radio" name="selling_plan" value="subscribe">
              <span class="b-pdp__buy-option-label">Subscribe & save 15%<span class="b-pdp__buy-option-meta">Every 6 weeks · Skip or cancel anytime</span></span>
            </span>
            <span style="display: flex; align-items: center; gap: 8px;"><span class="b-pdp__buy-option-save">SAVE 15%</span><span style="font-weight: 700;">${{ product.price | divided_by: 100.0 | times: 0.85 | round: 2 }}</span></span>
          </label>
        </div>

        <div class="b-pdp__cta-row">
          <button type="submit" class="b-pdp__cta">Add to cart · {{ product.price | money }}</button>
        </div>
      </form>

      <div class="b-pdp__trust">
        <div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 12 2 2 4-4"/><path d="M21 12c-1 0-3-1-3-3s2-3 3-3 3 1 3 3-2 3-3 3M3 12c1 0 3-1 3-3s-2-3-3-3-3 1-3 3 2 3 3 3M12 3c0 1-1 3-3 3s-3-2-3-3 1-3 3-3 3 2 3 3M12 21c0-1-1-3-3-3s-3 2-3 3 1 3 3 3 3-2 3-3"/></svg><span>Vegan + Cruelty-free</span></div>
        <div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>30-day money-back</span></div>
        <div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><span>1% to EMC</span></div>
      </div>

      <div class="b-pdp__desc">
        <h3 style="font-size: 17px; margin: 0 0 12px;">About the Booty Scrub</h3>
        <div class="b-pdp__desc-content" id="bDescContent">{{ product.description }}</div>
        <button type="button" class="b-pdp__desc-toggle" id="bDescToggle">Read more <span style="display:inline-block; transition: transform 200ms ease;">↓</span></button>
      </div>
    </div>
  </div>

  {%- assign ingredients = product.metafields.becky.key_ingredients.value -%}
  {%- if ingredients and ingredients.size > 0 -%}
  <section class="b-section">
    <h2 class="b-section__title">What's in it (and what it does)</h2>
    <div class="b-ingredients">
      {%- for ing in ingredients -%}
        <div class="b-ingredient">
          <h3>{{ ing.name | strip_html | escape }}</h3>
          <p>{{ ing.benefit | strip_html | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </section>
  {%- endif -%}

  {%- assign best_for = product.metafields.becky.best_for.value -%}
  {%- if best_for and best_for.size > 0 -%}
  <section class="b-section">
    <h2 class="b-section__title">Made for skin dealing with</h2>
    <div class="b-best-for">
      <div class="b-best-for__list">
        {%- for condition in best_for -%}
          <span class="b-best-for__item">{{ condition | strip_html | escape }}</span>
        {%- endfor -%}
      </div>
    </div>
  </section>
  {%- endif -%}

  {%- assign steps = product.metafields.becky.use_steps.value -%}
  {%- if steps and steps.size > 0 -%}
  <section class="b-section">
    <h2 class="b-section__title">How to use it</h2>
    <div class="b-steps">
      {%- for step in steps -%}
        <div class="b-step">
          <div class="b-step__num"></div>
          <div>
            <h3>{{ step.title | strip_html | escape }}</h3>
            <p>{{ step.description | strip_html | escape }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </section>
  {%- endif -%}

  {%- assign timeline = product.metafields.becky.results_timeline.value -%}
  {%- if timeline and timeline.size > 0 -%}
  <section class="b-section">
    <h2 class="b-section__title">What to expect, when</h2>
    <div class="b-timeline">
      {%- for milestone in timeline -%}
        <div class="b-mile">
          <p class="b-mile__week">{{ milestone.timeframe | strip_html | escape }}</p>
          <p class="b-mile__title">{{ milestone.result | strip_html | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </section>
  {%- endif -%}

  <!-- JUNIP REVIEWS -->
  <section class="b-section" id="reviews">
    <h2 class="b-section__title">Reviews</h2>
    <div style="max-width: 1000px; margin: 0 auto;">
      <junip-product-review product-id="{{ product.id }}"></junip-product-review>
    </div>
  </section>

  {%- assign faqs = product.metafields.becky.faq_entries.value -%}
  {%- if faqs and faqs.size > 0 -%}
  <section class="b-section">
    <h2 class="b-section__title">Frequently asked questions</h2>
    <div class="b-faq">
      {%- for faq in faqs -%}
        <details>
          <summary>{{ faq.question | strip_html | escape }}</summary>
          <div class="b-faq__answer">{{ faq.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </section>
  {%- endif -%}

</div>

<!-- STICKY ATC BAR (desktop + mobile, appears on scroll past hero) -->
<div class="b-sticky-atc" id="bStickyAtc">
  <div class="b-sticky-atc__img">
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.title | escape }}">
    {%- else -%}
      🍑
    {%- endif -%}
  </div>
  <div class="b-sticky-atc__info">
    <p class="b-sticky-atc__title">{{ product.title }}</p>
    <div class="b-sticky-atc__meta">
      <span>★ {{ rating }}</span>
      <span>·</span>
      <strong>{{ product.price | money }}</strong>
      <span>·</span>
      <span>Ships free $35+</span>
    </div>
  </div>
  <form action="/cart/add" method="post" style="margin: 0;">
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
    <button type="submit" class="b-sticky-atc__btn">Add to cart</button>
  </form>
</div>

<script>
  (function(){
    var toggle = document.getElementById('bDescToggle');
    var content = document.getElementById('bDescContent');
    if (toggle && content) {
      toggle.addEventListener('click', function(){
        content.classList.toggle('is-expanded');
        if (content.classList.contains('is-expanded')) {
          toggle.innerHTML = 'Read less <span style="display:inline-block; transform: rotate(180deg);">↓</span>';
        } else {
          toggle.innerHTML = 'Read more <span style="display:inline-block;">↓</span>';
        }
      });
    }
    // Show sticky ATC once user scrolls past hero
    var sticky = document.getElementById('bStickyAtc');
    if (sticky) {
      var heroBuyBtn = document.querySelector('.b-pdp__cta');
      var threshold = heroBuyBtn ? heroBuyBtn.getBoundingClientRect().top + window.scrollY + 100 : 800;
      window.addEventListener('scroll', function(){
        if (window.scrollY > threshold) sticky.classList.add('is-visible');
        else sticky.classList.remove('is-visible');
      }, { passive: true });
    }
  })();
</script>
