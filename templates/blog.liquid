{%- comment -%}
  Becky blog/atlas index — OS 1.0 liquid
  Shows all articles in the booty-atlas blog with TL;DR previews
{%- endcomment -%}

<style>
  .becky-atlas-hub { font-family: 'Work Sans', system-ui, sans-serif; color: #1a1a1a; max-width: 1200px; margin: 0 auto; padding: 0; }
  .becky-atlas-hub h1, .becky-atlas-hub h2, .becky-atlas-hub h3 { font-family: 'Poppins', 'Work Sans', system-ui, sans-serif; }
  .becky-atlas-hub__hero { background: linear-gradient(135deg, #f3e5fe 0%, #ffebeb 100%); padding: 80px 24px; text-align: center; border-radius: 0 0 32px 32px; }
  .becky-atlas-hub__title { font-size: clamp(36px, 6vw, 56px); margin: 0 0 16px; line-height: 1.1; text-wrap: balance; }
  .becky-atlas-hub__sub { font-size: 18px; max-width: 640px; margin: 0 auto; color: #555; line-height: 1.5; }

  .becky-atlas-hub__grid { padding: 64px 24px; display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; max-width: 1200px; margin: 0 auto; }
  .becky-atlas-hub__card { background: #fff; border: 1px solid #eee; border-radius: 16px; overflow: hidden; transition: all 200ms ease; display: block; text-decoration: none; color: inherit; }
  .becky-atlas-hub__card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,0.08); border-color: #ff3465; }
  .becky-atlas-hub__card-img { aspect-ratio: 4 / 3; background: linear-gradient(135deg, #ffebeb, #fddbd1); display: flex; align-items: center; justify-content: center; font-size: 60px; }
  .becky-atlas-hub__card-img img { width: 100%; height: 100%; object-fit: cover; }
  .becky-atlas-hub__card-body { padding: 24px; }
  .becky-atlas-hub__card-meta { font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: #888; margin: 0 0 12px; }
  .becky-atlas-hub__card-title { font-size: 20px; line-height: 1.3; margin: 0 0 12px; }
  .becky-atlas-hub__card-excerpt { font-size: 15px; line-height: 1.5; color: #555; margin: 0; }

  .becky-atlas-hub__pager { display: flex; justify-content: center; gap: 12px; padding: 32px 0 64px; }
  .becky-atlas-hub__pager a, .becky-atlas-hub__pager span { padding: 10px 18px; border-radius: 999px; font-weight: 600; text-decoration: none; color: #1a1a1a; border: 2px solid #1a1a1a; }
  .becky-atlas-hub__pager a:hover { background: #1a1a1a; color: #fff; }
  .becky-atlas-hub__pager span { background: #ff3465; color: #fff; border-color: #ff3465; }
</style>

<div class="becky-atlas-hub">

  <section class="becky-atlas-hub__hero">
    <h1 class="becky-atlas-hub__title">The Booty Atlas</h1>
    <p class="becky-atlas-hub__sub">{{ blog.title | escape | default: 'The Booty Atlas' }} — everything we know about the skin between your hip and your knee. Conditions, ingredients, routines, comparisons. Researched, written, real.</p>
  </section>

  {%- paginate blog.articles by 12 -%}
  <div class="becky-atlas-hub__grid">
    {%- for article in blog.articles -%}
      <a href="{{ article.url }}" class="becky-atlas-hub__card">
        <div class="becky-atlas-hub__card-img">
          {%- if article.image -%}
            <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}" loading="lazy">
          {%- else -%}
            🍑
          {%- endif -%}
        </div>
        <div class="becky-atlas-hub__card-body">
          <p class="becky-atlas-hub__card-meta">
            {%- if article.metafields.becky.reading_time_min -%}{{ article.metafields.becky.reading_time_min }} min read · {%- endif -%}
            {{ article.published_at | date: '%b %-d, %Y' }}
          </p>
          <h3 class="becky-atlas-hub__card-title">{{ article.title }}</h3>
          <p class="becky-atlas-hub__card-excerpt">{{ article.metafields.becky.tldr | default: article.excerpt | strip_html | truncate: 160 }}</p>
        </div>
      </a>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <div class="becky-atlas-hub__pager">
      {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">← Previous</a>{%- endif -%}
      <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
      {%- if paginate.next -%}<a href="{{ paginate.next.url }}">Next →</a>{%- endif -%}
    </div>
  {%- endif -%}
  {%- endpaginate -%}

</div>
